{
  "name": "Suflae",
  "scopeName": "source.sf",
  "fileTypes": ["sf", "suflae"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#text-literals" },
    { "include": "#letter-literals" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "comment": "Documentation comment",
          "name": "comment.block.documentation.sf",
          "match": "###.*$"
        },
        {
          "comment": "Line comment",
          "name": "comment.line.sf",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "comment": "Type declarations",
          "name": "storage.type.sf",
          "match": "\\b(routine|entity|record|variant|choice|protocol|flags|crashable)\\b"
        },
        {
          "comment": "Variable declarations",
          "name": "keyword.declaration.sf",
          "match": "\\b(var|preset|common|define)\\b"
        },
        {
          "comment": "Access and routine modifiers",
          "name": "keyword.modifier.sf",
          "match": "\\b(secret|posted|global|suspended|emitting)\\b"
        },
        {
          "comment": "Control flow",
          "name": "keyword.control.sf",
          "match": "\\b(if|elseif|else|then|unless|for|loop|while|when|break|continue|return|throw|absent|becomes|discard|emit)\\b"
        },
        {
          "comment": "Type and pattern operations",
          "name": "keyword.operator.sf",
          "match": "\\b(is|isnot|isonly|obeys|disobeys|in|notin|but)\\b"
        },
        {
          "comment": "Module system",
          "name": "keyword.control.import.sf",
          "match": "\\b(import|module)\\b"
        },
        {
          "comment": "Resource management",
          "name": "keyword.control.sf",
          "match": "\\b(using)\\b"
        },
        {
          "comment": "Async",
          "name": "keyword.control.sf",
          "match": "\\b(waitfor|within|after)\\b"
        },
        {
          "comment": "Generic constraints",
          "name": "keyword.other.sf",
          "match": "\\b(needs)\\b"
        },
        {
          "comment": "Logical operators",
          "name": "keyword.operator.logical.sf",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "comment": "Self reference",
          "name": "variable.language.sf",
          "match": "\\b(me|Me)\\b"
        },
        {
          "comment": "Range keywords",
          "name": "keyword.operator.sf",
          "match": "\\b(to|til|by)\\b"
        },
        {
          "comment": "Special keywords",
          "name": "keyword.other.sf",
          "match": "\\b(as|pass|with|given)\\b"
        },
        {
          "comment": "Boolean literals",
          "name": "constant.language.boolean.sf",
          "match": "\\b(true|false)\\b"
        },
        {
          "comment": "None literal",
          "name": "constant.language.null.sf",
          "match": "\\b(None)\\b"
        }
      ]
    },
    "text-literals": {
      "patterns": [
        {
          "comment": "Prefixed text literals (br, rf, b, r, f)",
          "name": "string.quoted.double.sf",
          "begin": "(br|rf|b|r|f)\"",
          "beginCaptures": {
            "1": { "name": "storage.modifier.sf" }
          },
          "end": "\"",
          "patterns": [{ "include": "#escapes" }]
        },
        {
          "comment": "Text literal",
          "name": "string.quoted.double.sf",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "include": "#escapes" }]
        }
      ]
    },
    "escapes": {
      "patterns": [
        {
          "comment": "Unicode escape \\uXXXXXX (6 hex)",
          "name": "constant.character.escape.sf",
          "match": "\\\\u[0-9a-fA-F]{6}"
        },
        {
          "comment": "Hex byte escape \\xFF (2 hex)",
          "name": "constant.character.escape.sf",
          "match": "\\\\x[0-9a-fA-F]{2}"
        },
        {
          "comment": "Simple escapes",
          "name": "constant.character.escape.sf",
          "match": "\\\\[nrt0\\\\\"']"
        }
      ]
    },
    "letter-literals": {
      "patterns": [
        {
          "comment": "Byte literal byte'x'",
          "name": "string.quoted.single.sf",
          "begin": "byte'",
          "beginCaptures": { "0": { "name": "storage.modifier.sf" } },
          "end": "'",
          "patterns": [{ "include": "#escapes" }]
        },
        {
          "comment": "Letter literal letter'x'",
          "name": "string.quoted.single.sf",
          "begin": "letter'",
          "beginCaptures": { "0": { "name": "storage.modifier.sf" } },
          "end": "'",
          "patterns": [{ "include": "#escapes" }]
        },
        {
          "comment": "Letter literal 'x'",
          "name": "string.quoted.single.sf",
          "begin": "'",
          "end": "'",
          "patterns": [{ "include": "#escapes" }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "Hex number",
          "name": "constant.numeric.sf",
          "match": "\\b0x[0-9a-fA-F_]+([a-z0-9]+)?\\b"
        },
        {
          "comment": "Binary number",
          "name": "constant.numeric.sf",
          "match": "\\b0b[01_]+([a-z0-9]+)?\\b"
        },
        {
          "comment": "Octal number",
          "name": "constant.numeric.sf",
          "match": "\\b0o[0-7_]+([a-z0-9]+)?\\b"
        },
        {
          "comment": "Quaternary number",
          "name": "constant.numeric.sf",
          "match": "\\b0q[0-3_]+([a-z0-9]+)?\\b"
        },
        {
          "comment": "Float with suffix",
          "name": "constant.numeric.sf",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]+([eE][+-]?[0-9_]+)?([a-z0-9]+)?\\b"
        },
        {
          "comment": "Integer with suffix",
          "name": "constant.numeric.sf",
          "match": "\\b[0-9][0-9_]*([a-z]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "comment": "Intrinsic type attribute",
          "name": "keyword.other.sf",
          "match": "@intrinsic\\b"
        },
        {
          "comment": "Compound annotation",
          "name": "storage.modifier.annotation.sf",
          "match": "@\\[[a-zA-Z_][a-zA-Z0-9_, ]*\\]"
        },
        {
          "comment": "Annotation",
          "name": "storage.modifier.annotation.sf",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "comment": "Arrows",
          "name": "keyword.operator.sf",
          "match": "(->|=>)"
        },
        {
          "comment": "Three-way comparison",
          "name": "keyword.operator.sf",
          "match": "<=>"
        },
        {
          "comment": "Shift operators",
          "name": "keyword.operator.sf",
          "match": "(<<<|>>>|<<|>>)"
        },
        {
          "comment": "Comparison",
          "name": "keyword.operator.sf",
          "match": "(===|!==|==|!=|<=|>=|<|>)"
        },
        {
          "comment": "Power operators",
          "name": "keyword.operator.sf",
          "match": "(\\*\\*[%^]?=?)"
        },
        {
          "comment": "Integer division",
          "name": "keyword.operator.sf",
          "match": "//=?"
        },
        {
          "comment": "Overflow arithmetic",
          "name": "keyword.operator.sf",
          "match": "[+\\-*][%^]=?"
        },
        {
          "comment": "Optional/coalesce operators",
          "name": "keyword.operator.sf",
          "match": "(\\?\\?=?|\\?\\.?|!!)"
        },
        {
          "comment": "Assignment",
          "name": "keyword.operator.sf",
          "match": "[+\\-*/%&|^]=|="
        },
        {
          "comment": "Basic operators",
          "name": "keyword.operator.sf",
          "match": "[+\\-*/%&|^~!]"
        },
        {
          "comment": "Colon for type annotations",
          "name": "punctuation.separator.sf",
          "match": ":"
        }
      ]
    }
  }
}
