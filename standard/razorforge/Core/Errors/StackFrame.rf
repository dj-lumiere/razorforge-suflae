module Core

# StackFrame - Runtime stack frame for error tracking
#
# Each frame represents a single routine call in the call stack.
# All fields are U32 IDs that reference compiler-generated lookup tables.

record StackFrame {
    file_id: U32
    routine_id: U32
    namespace_id: U32
    type_id: U32
    line_no: U32
    column_no: U32
}
