    if ch.is_numeric()
      result = result * 10u128 + U128(ch.digit_value())
    i = i + 1u64
  return result

routine Address.__create__!(from_text: Text) -> Address
  # Parses hex format: 0xXXXX_XXXX_XXXX_XXXX
  var result = 0_a
  var i = 0u64
  while i < from_text.count()
    var cp = from_text[i].codepoint()
    if 0x0030u32 <= cp <= 0x0039u32
      result = result * 16_a + Address(cp - 0x0030u32)
    elseif 0x0041u32 <= cp <= 0x0046u32
      result = result * 16_a + Address(cp - 0x0041u32 + 10u32)
    elseif 0x0061u32 <= cp <= 0x0066u32
      result = result * 16_a + Address(cp - 0x0061u32 + 10u32)
    i = i + 1u64
  return result

# ============================================================================
# Binary Floating Point
# ============================================================================

routine F16.__create__!(from_text: Text) -> F16
  var cstr_val = from_text.CStr()
  return rf_parse_F16(cstr_val)

routine F32.__create__!(from_text: Text) -> F32
  var cstr_val = from_text.CStr()
  return rf_parse_F32(cstr_val)

routine F64.__create__!(from_text: Text) -> F64
  var cstr_val = from_text.CStr()
  return rf_parse_F64(cstr_val)

routine F128.__create__!(from_text: Text) -> F128
  var cstr_val = from_text.CStr()
  return rf_parse_F128(cstr_val)

# ============================================================================
# Decimal Floating Point
# ============================================================================

routine D32.__create__!(from_text: Text) -> D32
  var cstr_val = from_text.CStr()
  var bits = rf_D32_from_string(cstr_val)
  return bitcast[U32, D32](bits)

routine D64.__create__!(from_text: Text) -> D64
  var cstr_val = from_text.CStr()
  var bits = rf_D64_from_string(cstr_val)
  return bitcast[U64, D64](bits)

routine D128.__create__!(from_text: Text) -> D128
  var cstr_val = from_text.CStr()
  return rf_D128_from_string(cstr_val)
