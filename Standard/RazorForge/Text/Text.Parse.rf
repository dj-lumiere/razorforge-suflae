module Core

# Parsing routines for Core types
#
# These X.__create__!(from_text:) routines parse text into Core types.
# They were moved here from Core module files to eliminate the
# Core → Text dependency during stdlib loading.
#
# Integer parsing is pure RazorForge — digit accumulation from Text letters.
# Float/decimal parsing still uses native C functions via CStr.

# ============================================================================
# Signed Integers
# ============================================================================

routine S8.__create__!(from_text: Text) -> S8
  var start = 0u64
  var negative = false
  if from_text.count() > 0u64
    var first = from_text[0u64]
    if first == Letter(value: 0x002Du32)
      negative = true
      start = 1u64
    elseif first == Letter(value: 0x002Bu32)
      start = 1u64
  var result = 0u32
  var i = start
  while i < from_text.count()
    var ch = from_text[i]
    if ch.is_numeric()
      result = result * 10u32 + U32(ch.digit_value())
    i = i + 1u64
  if negative
    return S8(0u32 - result)
  return S8(result)

