# RazorForge SortedSet[T] - B-tree based sorted set
# Entity type with heap allocation
# O(log n) insert, delete, search, and indexing
# Elements are unique and always in sorted order
#
# Usage:
#   var set = SortedSet[S32]()
#   set.add(5)
#   set.add(1)
#   set.add(3)
#   var first = set[0]     # 1 (O(log n) access)
#   var last = set[^1]     # 5
#   var range = set.range(1, 10)

module Collections

import BuilderService

# B-tree order (max children per node)
# B = 32 means each node has 16-31 keys (except root)
preset B: U64 = 32u64
preset MIN_KEYS: U64 = 15u64  # B/2 - 1

### Defines the entity `BTreeSetNode`.
### :typeparam T: The value used for `T`.
entity BTreeSetNode[T]
needs T obeys Comparable
  keys: List[T]                       # Keys in this node
  children: List[BTreeSetNode[T]]     # Child pointers (empty for leaf)
  subtree_size: U64                 # Total elements in this subtree
  is_leaf: Bool

### Defines the entity `SortedSet`.
### :typeparam T: The value used for `T`.
entity SortedSet[T] obeys Iterable[T]
needs T obeys Comparable
  secret root: BTreeSetNode[T]?
  secret count: U64

# ============================================================================
# Node Creators
# ============================================================================

### Creates a new instance.
### :param is_leaf: The `is_leaf` value.
### :returns: The resulting `BTreeSetNode[T]` value.
routine BTreeSetNode[T].$create(is_leaf: Bool) -> BTreeSetNode[T]
  return BTreeSetNode[T](
    keys: List[T](),
    children: List[BTreeSetNode[T]](),
    subtree_size: 0u64,
    is_leaf: is_leaf
  )

# ============================================================================
# SortedSet Creators
# ============================================================================

### Creates a new instance.
### :returns: The resulting `SortedSet[T]` value.
routine SortedSet[T].$create() -> SortedSet[T]
  return SortedSet[T](
    root: None,
    count: 0u64
  )

### Creates a new instance.
### :param values...: The `values...` value.
### :returns: The resulting `SortedSet[T]` value.
routine SortedSet[T].$create(values...: T) -> SortedSet[T]
  var result = SortedSet[T]()
  for v in values
    result.add(v)
  return result

# ============================================================================
# Core Operations
# ============================================================================

### Returns the number of stored values.
### :returns: The resulting `U64` value.
routine SortedSet[T].count() -> U64
  return me.count

### Returns true if this value is empty.
### :returns: The resulting `Bool` value.
routine SortedSet[T].is_empty() -> Bool
  return me.count == 0u64

### Removes all stored values.
routine SortedSet[T].clear()
  me.root = None
  me.count = 0u64
  return

# ============================================================================
# Search
# ============================================================================

### Returns whether this value contains `value`.
### :param value: The value to use.
### :returns: The resulting `Bool` value.
@readonly
routine SortedSet[T].$contains(value: T) -> Bool
  if me.root is None
    return false
  return me.search_node(me.root!!, value)

### Returns the result of `search node`.
### :param node: The `node` value.
### :param value: The value to use.
### :returns: The resulting `Bool` value.
routine SortedSet[T].search_node(node: BTreeSetNode[T], value: T) -> Bool
  # Binary search for position in keys
  var i = 0u64
  while i < node.keys.count() and value > node.keys[i]
    i = i + 1u64

  # Check if found
  if i < node.keys.count() and value == node.keys[i]
    return true

  # If leaf, not found
  if node.is_leaf
    return false

  # Search in appropriate child
  return me.search_node(node.children[i], value)

# ============================================================================
# Insert
# ============================================================================

### Returns the result of `add`.
### :param value: The value to use.
### :returns: The resulting `Bool` value.
routine SortedSet[T].add(value: T) -> Bool
  # Returns true if inserted, false if already exists

  if me.root is None
    me.root = BTreeSetNode[T](is_leaf: true)
    me.root!!.keys.add_last(value)
    me.root!!.subtree_size = 1u64
    me.count = 1u64
    return true

  # Check if already exists
  if value in me
    return false

  # If root is full, split it
  if me.root!!.keys.count() >= B - 1u64
    var old_root = me.root!!
    var new_root = BTreeSetNode[T](is_leaf: false)
    new_root.children.add_last(old_root)
    me.split_child(new_root, 0u64)
    me.root = new_root
    me.update_subtree_size(new_root)

  me.insert_non_full(me.root!!, value)
  me.count = me.count + 1u64
  return true

### Performs `insert non full` on this value.
### :param node: The `node` value.
### :param value: The value to use.
routine SortedSet[T].insert_non_full(node: BTreeSetNode[T], value: T)
  var i = node.keys.count()

  if node.is_leaf
    # Find position and insert
    while i > 0u64 and value < node.keys[i - 1u64]
      i = i - 1u64
    # Insert at position i
    var keys_copy = List[T]()
    var j = 0u64
    while j < i
      keys_copy.add_last(node.keys[j])
      j = j + 1u64
    keys_copy.add_last(value)
    while j < node.keys.count()
      keys_copy.add_last(node.keys[j])
      j = j + 1u64
    node.keys = keys_copy
    node.subtree_size = node.subtree_size + 1u64
  else
    # Find child to descend into
    while i > 0u64 and value < node.keys[i - 1u64]
      i = i - 1u64

    # Split child if full
    if node.children[i].keys.count() >= B - 1u64
      me.split_child(node, i)
      if value > node.keys[i]
        i = i + 1u64

    me.insert_non_full(node.children[i], value)
    node.subtree_size = node.subtree_size + 1u64
  return

### Performs `split child` on this value.
### :param parent_node: The `parent_node` value.
### :param child_idx: The `child_idx` value.
routine SortedSet[T].split_child(parent_node: BTreeSetNode[T], child_idx: U64)
  var child = parent_node.children[child_idx]
  var mid = (B - 1u64) / 2u64

  # Create new node for right half
  var new_node = BTreeSetNode[T](is_leaf: child.is_leaf)

  # Move upper keys to new node
  var i = mid + 1u64
  while i < child.keys.count()
    new_node.keys.add_last(child.keys[i])
    i = i + 1u64

  # Move children if not leaf
  if not child.is_leaf
    i = mid + 1u64
    while i < child.children.count()
      new_node.children.add_last(child.children[i])
      i = i + 1u64

  # Get middle key to promote
  var mid_key = child.keys[mid]

  # Truncate child's keys
  var left_keys = List[T]()
  i = 0u64
  while i < mid
    left_keys.add_last(child.keys[i])
    i = i + 1u64
  child.keys = left_keys

  # Truncate child's children if not leaf
  if not child.is_leaf
    var left_children = List[BTreeSetNode[T]]()
    i = 0u64
    while i <= mid
      left_children.add_last(child.children[i])
      i = i + 1u64
    child.children = left_children

  # Update subtree sizes
  me.update_subtree_size(child)
  me.update_subtree_size(new_node)

  # Insert mid_key and new_node into parent
  var new_keys = List[T]()
  var new_children = List[BTreeSetNode[T]]()

  i = 0u64
  while i < child_idx
    new_keys.add_last(parent_node.keys[i])
    new_children.add_last(parent_node.children[i])
    i = i + 1u64
  new_keys.add_last(mid_key)
  new_children.add_last(child)
  new_children.add_last(new_node)
  while i < parent_node.keys.count()
    new_keys.add_last(parent_node.keys[i])
    i = i + 1u64
  i = child_idx + 1u64
  while i < parent_node.children.count()
    new_children.add_last(parent_node.children[i])
    i = i + 1u64

  parent_node.keys = new_keys
  parent_node.children = new_children
  return

### Performs `update subtree size` on this value.
### :param node: The `node` value.
routine SortedSet[T].update_subtree_size(node: BTreeSetNode[T])
  if node.is_leaf
    node.subtree_size = node.keys.count()
  else
    var size = node.keys.count()
    var i = 0u64
    while i < node.children.count()
      size = size + node.children[i].subtree_size
      i = i + 1u64
    node.subtree_size = size
  return

# ============================================================================
# Remove
# ============================================================================

### Returns the result of `remove`.
### :param value: The value to use.
### :returns: The resulting `Bool` value.
routine SortedSet[T].remove(value: T) -> Bool
  # Returns true if removed, false if not found
  if me.root is None
    return false

  if value notin me
    return false

  me.remove_from_node(me.root!!, value)
  me.count = me.count - 1u64

  # If root has no keys but has children, make first child the new root
  if me.root!!.keys.count() == 0u64 and not me.root!!.is_leaf
    me.root = me.root!!.children[0]

  # If tree is empty
  if me.root!!.keys.count() == 0u64
    me.root = None

  return true

### Removes a value using `remove_from_node`.
### :param node: The `node` value.
### :param value: The value to use.
routine SortedSet[T].remove_from_node(node: BTreeSetNode[T], value: T)
  # Find position of value
  var i = 0u64
  while i < node.keys.count() and value > node.keys[i]
    i = i + 1u64

  if i < node.keys.count() and value == node.keys[i]
    # Found in this node
    if node.is_leaf
      # Simply remove from leaf
      var new_keys = List[T]()
      var j = 0u64
      while j < node.keys.count()
        if j != i
          new_keys.add_last(node.keys[j])
        j = j + 1u64
      node.keys = new_keys
      node.subtree_size = node.subtree_size - 1u64
    else
      # Internal node - replace with predecessor or successor
      var pred = me.get_predecessor(node, i)
      node.keys[i] = pred
      me.remove_from_node(node.children[i], pred)
      node.subtree_size = node.subtree_size - 1u64
  else
    # Not in this node, descend to child
    if node.is_leaf
      return  # Not found

    me.remove_from_node(node.children[i], value)
    node.subtree_size = node.subtree_size - 1u64
  return

### Returns the predecessor component.
### :param node: The `node` value.
### :param idx: The `idx` value.
### :returns: The resulting `T` value.
routine SortedSet[T].get_predecessor(node: BTreeSetNode[T], idx: U64) -> T
  # Get the largest key in the left subtree of keys[idx]
  var current = node.children[idx]
  while not current.is_leaf
    current = current.children[current.children.count() - 1u64]
  return current.keys[current.keys.count() - 1u64]

# ============================================================================
# Indexing - O(log n) access by position
# ============================================================================

### Implements the wired routine behavior for this value.
### :param index: The zero-based position to use.
### :returns: The resulting `T` value.
### :throws: May throw {IndexOutOfBoundsError}.
routine SortedSet[T].$getitem![I](index: I) -> T
needs I obeys Integral
  var idx = index.U64()
  if idx >= me.count
    throw IndexOutOfBoundsError(index: idx, count: me.count)
  return me.get_by_rank(me.root!!, idx)

### Implements the wired routine behavior for this value.
### :param index: The zero-based position to use.
### :returns: The resulting `T` value.
routine SortedSet[T].$getitem![I](index: BackIndex[I]) -> T
needs I obeys Integral
  var idx = index.resolve(me.count)
  return me.get_by_rank(me.root!!, idx)

### Returns the by rank component.
### :param node: The `node` value.
### :param rank: The `rank` value.
### :returns: The resulting `T` value.
routine SortedSet[T].get_by_rank(node: BTreeSetNode[T], rank: U64) -> T
  # Get element at rank (0-indexed) in this subtree
  if node.is_leaf
    return node.keys[rank]

  var remaining = rank
  var i = 0u64

  while i < node.children.count()
    var child_size = node.children[i].subtree_size

    if remaining < child_size
      # Element is in this child
      return me.get_by_rank(node.children[i], remaining)

    remaining = remaining - child_size

    # Check if it's the key between children
    if i < node.keys.count()
      if remaining == 0u64
        return node.keys[i]
      remaining = remaining - 1u64

    i = i + 1u64

  # Should not reach here if rank is valid
  return node.keys[0]

# ============================================================================
# Range Queries
# ============================================================================

### Returns the result of `range`.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :returns: The resulting `List[T]` value.
routine SortedSet[T].range(min_val: T, max_val: T) -> List[T]
  # Get all elements in [min_val, max_val]
  var result = List[T]()
  if me.root is None
    return result
  me.range_collect(me.root!!, min_val, max_val, result)
  return result

### Performs `range collect` on this value.
### :param node: The `node` value.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :param result: The result storage location.
routine SortedSet[T].range_collect(node: BTreeSetNode[T], min_val: T, max_val: T, result: List[T])
  var i = 0u64

  while i < node.keys.count()
    # Visit left child if might contain elements >= min_val
    if not node.is_leaf and (i == 0u64 or node.keys[i - 1u64] >= min_val)
      me.range_collect(node.children[i], min_val, max_val, result)

    # Check this key
    var key = node.keys[i]
    if key >= min_val and key <= max_val
      result.add_last(key)

    i = i + 1u64

  # Visit rightmost child
  if not node.is_leaf
    me.range_collect(node.children[node.children.count() - 1u64], min_val, max_val, result)
  return

# ============================================================================
# Min/Max
# ============================================================================

### Returns the result of `min`.
### :returns: The resulting `T` value.
### :absent: Returns absent when the requested value is unavailable.
routine SortedSet[T].min!() -> T
  if me.is_empty()
    absent
  var node = me.root!!
  while not node.is_leaf
    node = node.children[0]
  return node.keys[0]

### Returns the result of `max`.
### :returns: The resulting `T` value.
### :absent: Returns absent when the requested value is unavailable.
routine SortedSet[T].max!() -> T
  if me.is_empty()
    absent
  var node = me.root!!
  while not node.is_leaf
    node = node.children[node.children.count() - 1u64]
  return node.keys[node.keys.count() - 1u64]

### Returns the result of `first`.
### :returns: The resulting `T` value.
routine SortedSet[T].first!() -> T
  return me.min!()

### Returns the result of `last`.
### :returns: The resulting `T` value.
routine SortedSet[T].last!() -> T
  return me.max!()

# ============================================================================
# Iteration (in-order traversal)
# ============================================================================

### Creates an iterator for this value.
### :returns: The resulting `SortedSetIterator[T]` value.
@readonly
routine SortedSet[T].$iter() -> SortedSetIterator[T]
  return SortedSetIterator[T](set: me, index: 0u64)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `List[T]` value.
routine List[T].$create(from: SortedSet[T]) -> List[T]
  var result = List[T](from.count)
  if from.root is None
    return result
  from.collect_inorder(from.root!!, result)
  return result

### Performs `collect inorder` on this value.
### :param node: The `node` value.
### :param result: The result storage location.
routine SortedSet[T].collect_inorder(node: BTreeSetNode[T], result: List[T])
  var i = 0u64
  while i < node.keys.count()
    if not node.is_leaf
      me.collect_inorder(node.children[i], result)
    result.add_last(node.keys[i])
    i = i + 1u64
  if not node.is_leaf
    me.collect_inorder(node.children[node.children.count() - 1u64], result)
  return

### Defines the entity `SortedSetIterator`.
### :typeparam T: The value used for `T`.
entity SortedSetIterator[T] obeys Iterator[T]
  ### Stores the set member value.
  set: SortedSet[T]
  ### Stores the index member value.
  index: U64

### Returns the next value from this iterator.
### :returns: The resulting `T` value.
### :absent: Returns absent when the requested value is unavailable.
@writable
emitting routine SortedSetIterator[T].$next() -> T
  if me.index >= me.set.count()
    absent
  emit me.set[me.index]
  me.index = me.index + 1u64
  return

# ============================================================================
# Comparison
# ============================================================================

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine SortedSet[T].$represent() -> Text
  var result = "SortedSet{"
  var i = 0u64
  for v in me
    if i > 0u64
      result = result + ", "
    result = result + v.$represent()
    i = i + 1u64
  result = result + "}"
  return result

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine SortedSet[T].$diagnose() -> Text
  var result = me.type_name() + "(count: " + me.count().$represent() + ", {"
  var i = 0u64
  for v in me
    if i > 0u64
      result = result + ", "
    result = result + v.$represent()
    i = i + 1u64
  result = result + "})"
  return result

### Returns whether both values are equal.
### :param other: The other value to compare against.
### :returns: The resulting `Bool` value.
routine SortedSet[T].$eq(other: SortedSet[T]) -> Bool
  if me.count != other.count
    return false
  var i = 0u64
  while i < me.count
    if me[i] != other[i]
      return false
    i = i + 1u64
  return true
