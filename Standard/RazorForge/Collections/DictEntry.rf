# DictEntry[K, V] - Key-value pair record for dict-like constructors
# Used by Dict(1:2, 3:4) and SortedDict(1:2, 3:4) literal syntax
# Also used as the element type for Dict/SortedDict iteration

module Core

### Defines the record `DictEntry`.
### :typeparam K: The value used for `K`.
### :typeparam V: The value used for `V`.
record DictEntry[K, V]
  ### Stores the key member value.
  key: K
  ### Stores the value member value.
  value: V
