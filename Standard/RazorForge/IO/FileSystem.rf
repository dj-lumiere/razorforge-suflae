### Returns the result of `file stem`.
### :param path: The `path` value.
### :returns: The resulting `Text` value.
routine file_stem(path: Text) -> Text
  var cstr = CStr(from: path)
  var ptr = rf_fs_file_stem(cstr, cstr.count().S32())
  var len = rf_get_result_len()
  var bytes = Bytes(ptr: ptr, count: len)
  return bytes.decode_as_utf8_lossy()

### Returns the result of `extension`.
### :param path: The `path` value.
### :returns: The resulting `Text` value.
routine extension(path: Text) -> Text
  var cstr = CStr(from: path)
  var ptr = rf_fs_extension(cstr, cstr.count().S32())
  var len = rf_get_result_len()
  var bytes = Bytes(ptr: ptr, count: len)
  return bytes.decode_as_utf8_lossy()

# ============================================================================
# Path resolution (OS calls, failable)
# ============================================================================

### Returns the result of `absolute path`.
### :param path: The `path` value.
### :returns: The resulting `Text` value.
### :throws: May throw {IOError}.
routine absolute_path!(path: Text) -> Text
  var cstr = CStr(from: path)
  var ptr = rf_fs_absolute_path(cstr, cstr.count().S32())
  var len = rf_get_result_len()
  if ptr.is_none()
    throw IOError(description: f"Cannot resolve absolute path: {path}")
  var bytes = Bytes(ptr: ptr, count: len)
  return bytes.decode_as_utf8_lossy()

### Returns the result of `canonical path`.
### :param path: The `path` value.
### :returns: The resulting `Text` value.
### :throws: May throw {IOError}.
routine canonical_path!(path: Text) -> Text
  var cstr = CStr(from: path)
  var ptr = rf_fs_canonical_path(cstr, cstr.count().S32())
  var len = rf_get_result_len()
  if ptr.is_none()
    throw IOError(description: f"Cannot resolve canonical path: {path}")
  var bytes = Bytes(ptr: ptr, count: len)
  return bytes.decode_as_utf8_lossy()

# ============================================================================
# Permissions
# ============================================================================

### Returns the result of `can read`.
### :param path: The `path` value.
### :returns: The resulting `Bool` value.
routine can_read(path: Text) -> Bool
  var cstr = CStr(from: path)
  return rf_fs_can_read(cstr, cstr.count().S32())

### Returns the result of `can write`.
### :param path: The `path` value.
### :returns: The resulting `Bool` value.
routine can_write(path: Text) -> Bool
  var cstr = CStr(from: path)
  return rf_fs_can_write(cstr, cstr.count().S32())

### Returns the result of `can execute`.
### :param path: The `path` value.
### :returns: The resulting `Bool` value.
routine can_execute(path: Text) -> Bool
  var cstr = CStr(from: path)
  return rf_fs_can_execute(cstr, cstr.count().S32())

### Sets the readonly component.
### :param path: The `path` value.
### :param readonly: The `readonly` value.
### :throws: May throw {IOError}.
routine set_readonly!(path: Text, readonly: Bool = true)
  var cstr = CStr(from: path)
  var result = rf_fs_set_readonly(cstr, cstr.count().S32(), readonly)
  if result == -1
    throw IOError(description: f"Cannot set readonly on: {path}")
  return
