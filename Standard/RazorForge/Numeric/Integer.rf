# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine Integer.is_zero() -> Bool
  return rf_bigint_is_zero(me.handle) != 0

### Returns true if this value is negative.
### :returns: The resulting `Bool` value.
routine Integer.is_negative() -> Bool
  return rf_bigint_is_neg(me.handle) != 0

### Returns true if this value is positive.
### :returns: The resulting `Bool` value.
routine Integer.is_positive() -> Bool
  return not me.is_zero() and not me.is_negative()

### Returns the result of `signum`.
### :returns: The resulting `S32` value.
routine Integer.signum() -> S32
  return when
    me.is_positive() => 1
    me.is_negative() => -1
    else => 0

# ============================================================================
# Conversions
# ============================================================================

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S64` value.
routine S64.$create!(from: Integer) -> S64
  return rf_bigint_get_i64(from.handle)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: Integer) -> U64
  return rf_bigint_get_u64(from.handle)

### Returns the textual representation of this value.
### :param radix: The numeric base to use.
### :returns: The resulting `Text` value.
routine Integer.$represent(radix: S32 = 10) -> Text
  var CStr = rf_bigint_get_str(me.handle, radix)
  var text = Text.from_cstr(CStr)
  rf_invalidate[Byte](CStr.ptr)
  return text

# ============================================================================
# Factory Methods
# ============================================================================

### Implements the wired routine behavior for this value.
### :param text: The `text` value.
### :returns: The resulting `Integer` value.
### :throws: May throw {ParseError}.
routine Integer.$create!(text: Text) -> Integer
  var int = Integer(handle: rf_bigint_new())
  var result = rf_bigint_set_str(int.handle, text.to_cstr(), 10)
  if result != 0
    rf_bigint_clear(int.handle)
    throw ParseError("Invalid integer form")
  return int

### Creates a value from binary.
### :param text: The `text` value.
### :returns: The resulting `Integer` value.
### :throws: May throw {ParseError}.
routine Integer.from_binary!(text: Text) -> Integer
  var int = Integer(handle: rf_bigint_new())
  var result = rf_bigint_set_str(int.handle, text.to_cstr(), 2)
  if result != 0
    rf_bigint_clear(int.handle)
    throw ParseError("Invalid integer form")
  return int

### Creates a value from hex.
### :param text: The `text` value.
### :returns: The resulting `Integer` value.
### :throws: May throw {ParseError}.
routine Integer.from_hex!(text: Text) -> Integer
  var int = Integer(handle: rf_bigint_new())
  var result = rf_bigint_set_str(int.handle, text.to_cstr(), 16)
  if result != 0
    rf_bigint_clear(int.handle)
    throw ParseError("Invalid integer form")
  return int

### Returns the zero value.
### :returns: The resulting `Integer` value.
routine Integer.zero() -> Integer
  return Integer(0_s64)

### Returns the result of `one`.
### :returns: The resulting `Integer` value.
routine Integer.one() -> Integer
  return Integer(1_s64)

# ============================================================================
# Examples
# ============================================================================

### Returns the result of `factorial`.
### :param n: The `n` value.
### :returns: The resulting `Integer` value.
routine factorial(n: Integer) -> Integer
  if n.is_zero() or n == Integer.one()
    return Integer.one()

  var result = Integer.one()
  var i = Integer(2_s64)

  while i <= n
    result = result * i
    i = i + Integer.one()

  return result

### Returns the result of `fibonacci big`.
### :param n: The `n` value.
### :returns: The resulting `Integer` value.
routine fibonacci_big(n: S64) -> Integer
  if n <= 1
    return Integer(n)

  var a = Integer.zero()
  var b = Integer.one()

  var i: S64 = 2
  while i <= n
    var temp = a + b
    a = b
    b = temp
    i = i + 1

  return b
