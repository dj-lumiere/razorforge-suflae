module Numerics

# RazorForge Integer - Arbitrary precision integer type
# Powered by LibTomMath (https://github.com/libtom/libtommath)
# License: Public Domain (Unlicense)

### Defines the entity `Integer`.
entity Integer obeys Integral, Divisible, Negatable, Ordered
  ### Stores the handle member value.
  secret handle: BigIntHandle

# ============================================================================
# Lifecycle Management
# ============================================================================

### Creates a new instance.
### :returns: The resulting `Integer` value.
routine Integer.$create() -> Integer
  var int = Integer(handle: rf_bigint_new())
  return int

### Creates a new instance.
### :param value: The value to use.
### :returns: The resulting `Integer` value.
routine Integer.$create(value: S64) -> Integer
  var int = Integer(handle: rf_bigint_new())
  rf_bigint_set_i64(int.handle, value)
  return int

### Creates a new instance.
### :param value: The value to use.
### :returns: The resulting `Integer` value.
routine Integer.$create(value: U64) -> Integer
  var int = Integer(handle: rf_bigint_new())
  rf_bigint_set_u64(int.handle, value)
  return int

### Implements the wired routine behavior for this value.
### :param text: The `text` value.
### :param radix: The numeric base to use.
### :returns: The resulting `Integer` value.
### :throws: May throw {ValueError}.
routine Integer.$create!(text: Text, radix: S32 = 10) -> Integer
  var int = Integer(handle: rf_bigint_new())
  var result = rf_bigint_set_str(int.handle, text.to_cstr(), radix)
  if result != 0
    throw ValueError(f"Invalid integer string: {text}")
  return int

### Releases the resources owned by this value.
routine Integer.$destroy()
  rf_bigint_clear(me.handle)
  return

### Implements the wired routine behavior for this value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$copy(other: Integer) -> Integer
  var int = Integer(handle: rf_bigint_new())
  rf_bigint_copy(int.handle, other.handle)
  return int

# ============================================================================
# Arithmetic Operations
# ============================================================================

### Returns the sum of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$add(other: Integer) -> Integer
  var result = Integer(handle: rf_bigint_new())
  rf_bigint_add(result.handle, me.handle, other.handle)
  return result

### Returns the difference between this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$sub(other: Integer) -> Integer
  var result = Integer(handle: rf_bigint_new())
  rf_bigint_sub(result.handle, me.handle, other.handle)
  return result

### Returns the product of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$mul(other: Integer) -> Integer
  var result = Integer(handle: rf_bigint_new())
  rf_bigint_mul(result.handle, me.handle, other.handle)
  return result

### Returns the quotient of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$floordiv(other: Integer) -> Integer
  var quotient = Integer(handle: rf_bigint_new())
  var remainder = Integer(handle: rf_bigint_new())
  rf_bigint_div(quotient.handle, remainder.handle, me.handle, other.handle)
  rf_bigint_clear(remainder.handle)
  return quotient

### Implements the wired routine behavior for this value.
### :param other: The other value to compare against.
### :returns: The resulting `Integer` value.
routine Integer.$rem(other: Integer) -> Integer
  var result = Integer(handle: rf_bigint_new())
  rf_bigint_mod(result.handle, me.handle, other.handle)
  return result

### Returns the negated value.
### :returns: The resulting `Integer` value.
routine Integer.$neg() -> Integer
  var result = Integer(handle: rf_bigint_new())
  rf_bigint_neg(result.handle, me.handle)
  return result

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine Integer.$eq(you: Integer) -> Bool
  return rf_bigint_cmp(me.handle, other.handle) == 0

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `CompareSign` value.
routine Integer.$cmp(you: Integer) -> CompareSign
  var comparison_value = rf_bigint_cmp(me.handle, other.handle)
  if comparison_value < 0
    return LEFT_SMALL
  elseif comparison_value > 0
    return RIGHT_SMALL
  else
    return SAME

