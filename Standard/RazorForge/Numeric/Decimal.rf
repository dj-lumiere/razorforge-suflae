### Returns the result of `atan`.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine Decimal.atan(precision: S32 = DECIMAL_DEFAULT_PRECISION) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_atan(result.handle, precision, me.handle)
  return result

### Returns the result of `atan2`.
### :param x: The x value.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine Decimal.atan2(x: Decimal, precision: S32 = DECIMAL_DEFAULT_PRECISION) -> Decimal
  if x.is_zero()
    return when
      me.is_positive() => Decimal.pi(precision).divide(Decimal(2_s64), precision)
      me.is_negative() => -Decimal.pi(precision).divide(Decimal(2_s64), precision)
      else => Decimal.zero()

  var theta = me.divide(x, precision + 4).atan(precision)
  if x.is_positive()
    return theta

  var pi = Decimal.pi(precision)
  if me.is_negative()
    return theta - pi
  return theta + pi

### Returns the result of `sinh`.
### :param precision: The decimal precision to use.
