module Numerics

# RazorForge Decimal - Arbitrary precision decimal floating-point type
# Powered by MAPM - Mike's Arbitrary Precision Math Library
# https://github.com/LuaDist/mapm
# License: Freeware

# Default precision for operations (decimal places)
preset DECIMAL_DEFAULT_PRECISION: S32 = 50

### Defines the entity `Decimal`.
entity Decimal obeys Numeric, Ordered
  ### Stores the handle member value.
  secret handle: BigDecHandle

# ============================================================================
# Lifecycle Management
# ============================================================================

### Creates a new instance.
### :returns: The resulting `Decimal` value.
routine Decimal.$create() -> Decimal
  var dec = Decimal(handle: rf_bigdec_new())
  rf_bigdec_set_i64(dec.handle, 0)
  return dec

### Creates a new instance.
### :param value: The value to use.
### :returns: The resulting `Decimal` value.
routine Decimal.$create(value: S64) -> Decimal
  var dec = Decimal(handle: rf_bigdec_new())
  rf_bigdec_set_i64(dec.handle, value)
  return dec

### Creates a new instance.
### :param value: The value to use.
### :returns: The resulting `Decimal` value.
routine Decimal.$create(value: F64) -> Decimal
  var dec = Decimal(handle: rf_bigdec_new())
  rf_bigdec_set_f64(dec.handle, value)
  return dec

### Implements the wired routine behavior for this value.
### :param text: The `text` value.
### :returns: The resulting `Decimal` value.
routine Decimal.$create!(text: Text) -> Decimal
  var dec = Decimal(handle: rf_bigdec_new())
  rf_bigdec_set_str(dec.handle, text.to_cstr())
  return dec

### Releases the resources owned by this value.
routine Decimal.$destroy()
  rf_bigdec_free(me.handle)
  return

### Implements the wired routine behavior for this value.
### :param other: The other value to compare against.
### :returns: The resulting `Decimal` value.
routine Decimal.$copy(other: Decimal) -> Decimal
  var dec = Decimal(handle: rf_bigdec_copy(other.handle))
  return dec

# ============================================================================
# Arithmetic Operations
# ============================================================================

### Returns the sum of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Decimal` value.
routine Decimal.$add(other: Decimal) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_add(result.handle, me.handle, other.handle)
  return result

### Returns the difference between this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Decimal` value.
routine Decimal.$sub(other: Decimal) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_sub(result.handle, me.handle, other.handle)
  return result

### Returns the product of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Decimal` value.
routine Decimal.$mul(other: Decimal) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_mul(result.handle, me.handle, other.handle)
  return result

### Returns the quotient of this value and the other value.
### :param other: The other value to compare against.
### :returns: The resulting `Decimal` value.
routine Decimal.$truediv(other: Decimal) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_div(result.handle, DECIMAL_DEFAULT_PRECISION, me.handle, other.handle)
  return result

### Returns the result of `divide`.
### :param other: The other value to compare against.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine Decimal.divide(other: Decimal, precision: S32) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_div(result.handle, precision, me.handle, other.handle)
  return result

### Returns the negated value.
### :returns: The resulting `Decimal` value.
routine Decimal.$neg() -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_neg(result.handle, me.handle)
  return result

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param other: The other value to compare against.
### :returns: The resulting `Bool` value.
routine Decimal.$eq(other: Decimal) -> Bool
  return rf_bigdec_cmp(me.handle, other.handle) == 0

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine Decimal.$cmp(you: Decimal) -> ComparisonSign
  var value = rf_bigdec_cmp(me.handle, other.handle)
  if value < 0
    return ME_SMALL
  elseif value > 0
    return ME_LARGE
  return SAME

