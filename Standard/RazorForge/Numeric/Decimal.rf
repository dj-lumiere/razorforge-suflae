# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine Decimal.is_zero() -> Bool
  return rf_bigdec_is_zero(me.handle) != 0

### Returns true if this value is negative.
### :returns: The resulting `Bool` value.
routine Decimal.is_negative() -> Bool
  return rf_bigdec_is_neg(me.handle) != 0

### Returns true if this value is positive.
### :returns: The resulting `Bool` value.
routine Decimal.is_positive() -> Bool
  return not me.is_zero() and not me.is_negative()

### Returns the result of `signum`.
### :returns: The resulting `S32` value.
routine Decimal.signum() -> S32
  return when
    me.is_positive() => 1
    me.is_negative() => -1
    else => 0

# ============================================================================
# Conversions
# ============================================================================

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `S64` value.
routine S64.$create(from: Decimal) -> S64
  return rf_bigdec_get_i64(from.handle)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: Decimal) -> F64
  return rf_bigdec_get_f64(from.handle)

### Returns the textual representation of this value.
### :param decimal_places: The number of decimal places to render.
### :returns: The resulting `Text` value.
routine Decimal.$represent(decimal_places: S32 = 10) -> Text
  var CStr = rf_bigdec_get_str(me.handle, decimal_places)
  var text = Text.from_cstr(CStr)
  rf_invalidate[Byte](CStr.ptr)
  return text

# ============================================================================
# Constants (computed with high precision)
# ============================================================================

### Returns the result of `pi`.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine Decimal.pi(precision: S32 = DECIMAL_DEFAULT_PRECISION) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_pi(result.handle, precision)
  return result

### Returns the result of `e`.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine Decimal.e(precision: S32 = DECIMAL_DEFAULT_PRECISION) -> Decimal
  var result = Decimal(handle: rf_bigdec_new())
  rf_bigdec_e(result.handle, precision)
  return result

# ============================================================================
# Factory Methods
# ============================================================================

### Returns the result of `parse`.
### :param text: The `text` value.
### :returns: The resulting `Maybe[Decimal]` value.
routine Decimal.parse(text: Text) -> Maybe[Decimal]
  var dec = Decimal(handle: rf_bigdec_new())
  rf_bigdec_set_str(dec.handle, text.to_cstr())
  # MAPM doesn't return error codes for parsing, so we just return the result
  return dec

### Returns the zero value.
### :returns: The resulting `Decimal` value.
routine Decimal.zero() -> Decimal
  return Decimal(0_s64)

### Returns the result of `one`.
### :returns: The resulting `Decimal` value.
routine Decimal.one() -> Decimal
  return Decimal(1_s64)

# ============================================================================
# Examples
# ============================================================================

### Returns the result of `exp taylor`.
### :param x: The x value.
### :param terms: The `terms` value.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine exp_taylor(x: Decimal, terms: S32 = 20, precision: S32 = 50) -> Decimal
  var result = Decimal.one()
  var term = Decimal.one()

  var i: S32 = 1
  while i <= terms
    term = term * x
    term = term.divide(Decimal(S64!(i)), precision)
    result = result + term
    i = i + 1

  return result

### Returns the result of `sqrt newton`.
### :param x: The x value.
### :param iterations: The `iterations` value.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine sqrt_newton(x: Decimal, iterations: S32 = 20, precision: S32 = 50) -> Decimal
  if x.is_zero() or x.is_negative()
    return Decimal.zero()

  var guess = x.divide(Decimal(2_s64), precision)
  var two = Decimal(2_s64)

  var i: S32 = 0
  while i < iterations
    # Newton-Raphson: guess = (guess + x/guess) / 2
    var quotient = x.divide(guess, precision)
    var sum = guess + quotient
    guess = sum.divide(two, precision)
    i = i + 1

  return guess

### Returns the result of `compute pi`.
### :param precision: The decimal precision to use.
### :returns: The resulting `Decimal` value.
routine compute_pi(precision: S32 = 50) -> Decimal
  var one = Decimal.one()
  var four = Decimal(4_s64)
  var five = Decimal(5_s64)
  var two_thirty_nine = Decimal(239_s64)

  var atan_1_5 = one.divide(five, precision + 10).atan(precision + 10)
  var atan_1_239 = one.divide(two_thirty_nine, precision + 10).atan(precision + 10)

  var pi_over_4 = four * atan_1_5 - atan_1_239
  return four * pi_over_4
