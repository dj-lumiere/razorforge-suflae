module Core

### Defines the crashable `InvalidValueError`.
crashable InvalidValueError
  ### Stores the input member value.
  input: Text
  ### Stores the target member value.
  target: Text

### Returns the result of `crash message`.
### :returns: The resulting `Text` value.
routine InvalidValueError.crash_message() -> Text
  return f"Cannot parse \"{me.input}\" as {me.target}."
