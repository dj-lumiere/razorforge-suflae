module Core

# IntegerOverflowError - Error for integer conversion overflow
# Used when converting between integer types and the value doesn't fit

### Defines the record `IntegerOverflowError`.
record IntegerOverflowError obeys Crashable
  pass

### Returns the result of `crash message`.
### :returns: The resulting `Text` value.
routine IntegerOverflowError.crash_message() -> Text
  return "Integer overflow: value does not fit in the target type."
