module Core

### Defines the record `IndeterminateResultError`.
record IndeterminateResultError obeys Crashable
  # No member variables needed, as this error only has one cause (0**0)
  pass

### Returns the result of `crash message`.
### :returns: The resulting `Text` value.
routine IndeterminateResultError.crash_message() -> Text
  return "Indeterminate form encountered: 0 ** 0 is undefined for integer arithmetic."
