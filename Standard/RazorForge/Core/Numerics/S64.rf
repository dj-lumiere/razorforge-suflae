### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S64` value.
routine S64.$ashl(bits: U32) -> S64
  return shift_left[S64](me, S64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S64` value.
routine S64.$shift_right_signed(bits: U32) -> S64
  return shift_right_signed[S64](me, S64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S64` value.
routine S64.$lshl(bits: U32) -> S64
  return shift_left[S64](me, S64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S64` value.
routine S64.$shift_right_unsigned(bits: U32) -> S64
  return shift_right_unsigned[S64](me, S64(bits))

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine S64.$eq(you: S64) -> Bool
  return int_eq[S64](me, you)

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine S64.$cmp(you: S64) -> ComparisonSign
  if signed_lt[S64](me, you)
    return ME_SMALL
  if signed_gt[S64](me, you)
    return ME_LARGE
  return SAME

# ============================================================================
# Math Operations
# ============================================================================

### Returns the absolute value.
### :returns: The resulting `S64` value.
routine S64.abs() -> S64
  return int_abs[S64](me)

### Returns the result of `min`.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.min(you: S64) -> S64
  if me <= you
    return me
  else
    return you

### Returns the result of `max`.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.max(you: S64) -> S64
  if me >= you
    return me
  else
    return you

### Returns the result of `clamp`.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :returns: The resulting `S64` value.
routine S64.clamp(min_val: S64, max_val: S64) -> S64
  return me.min(max_val).max(min_val)

# ============================================================================
# Bit Manipulation
# ============================================================================

### Returns the number of stored values.
### :returns: The resulting `S64` value.
routine S64.count_ones() -> S64
  return count_ones[S64](me)

### Returns the number of stored values.
### :returns: The resulting `S64` value.
routine S64.count_zeros() -> S64
  return 64_s64 -% me.count_ones()

### Returns the result of `leading zeros`.
### :returns: The resulting `S64` value.
routine S64.leading_zeros() -> S64
  return leading_zeros[S64](me)

### Returns the result of `trailing zeros`.
### :returns: The resulting `S64` value.
routine S64.trailing_zeros() -> S64
  return trailing_zeros[S64](me)

### Returns the result of `leading ones`.
### :returns: The resulting `S64` value.
routine S64.leading_ones() -> S64
  return me.$bitnot().leading_zeros()

### Returns the result of `trailing ones`.
### :returns: The resulting `S64` value.
routine S64.trailing_ones() -> S64
  return me.$bitnot().trailing_zeros()

### Returns the result of `reverse bits`.
### :returns: The resulting `S64` value.
routine S64.reverse_bits() -> S64
  return reverse_bits[S64](me)

### Returns the result of `swap bytes`.
### :returns: The resulting `S64` value.
routine S64.swap_bytes() -> S64
  return byte_swap[S64](me)

# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is positive.
### :returns: The resulting `Bool` value.
routine S64.is_positive() -> Bool
  return me > 0_s64

### Returns true if this value is negative.
### :returns: The resulting `Bool` value.
routine S64.is_negative() -> Bool
  return me < 0_s64

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine S64.is_zero() -> Bool
  return me == 0_s64

### Returns true if this value is even.
### :returns: The resulting `Bool` value.
routine S64.is_even() -> Bool
  var result = bit_and[S64](me, 1_s64)
  return int_eq[S64](result, 0_s64)

### Returns true if this value is odd.
### :returns: The resulting `Bool` value.
routine S64.is_odd() -> Bool
  return not me.is_even()

### Returns the result of `signum`.
### :returns: The resulting `S64` value.
routine S64.signum() -> S64
  return when
    me > 0_s64 => 1_s64
    me < 0_s64 => -1_s64
    else => 0_s64

### Returns true if this value is power of two.
### :returns: The resulting `Bool` value.
routine S64.is_power_of_two() -> Bool
  var is_pos = signed_gt[S64](me, 0_s64)
  var minus_one = sub[S64](me, 1_s64)
  var anded = bit_and[S64](me, minus_one)
  var is_zero = int_eq[S64](anded, 0_s64)
  return is_pos and is_zero

# ============================================================================
# Text Representation and Parsing
# ============================================================================

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine S64.$represent() -> Text
  if me == 0s64
    return "0"
  if me > 0s64
    return U64(me).$represent()
  return "-" + U64(0u64 -% U64(me)).$represent()

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine S64.$diagnose() -> Text
  return "S64(" + me.$represent() + ")"

### Implements the wired routine behavior for this value.
### :param from_text: The `from_text` value.
### :returns: The resulting `S64` value.
### :throws: May throw {InvalidValueError}.
routine S64.$create!(from_text: Text) -> S64
  if from_text.count() == 0u64
    throw InvalidValueError(input: from_text, target: "S64")
  var start = 0u64
  var negative = false
  var first = from_text[0u64]
  if first == Character(0x002Du32)
    negative = true
    start = 1u64
  elseif first == Character(0x002Bu32)
    start = 1u64
  if start >= from_text.count()
    throw InvalidValueError(input: from_text, target: "S64")
  var result = 0u64
  var i = start
  while i < from_text.count()
    var ch = from_text[i]
    if ch.is_numeric()
      result = result * 10u64 + U64(ch.digit_value())
    else
      throw InvalidValueError(input: from_text, target: "S64")
    i = i + 1u64
  if negative
    return S64(0u64 - result)
  return S64(result)

# ============================================================================
# Hashing
# ============================================================================

### Returns a hash of this value.
### :returns: The resulting `U64` value.
routine S64.$hash() -> U64
  return __hash_leaf(v: reinterpret_bits[S64, U64](me))

### Returns a keyed hash of this value using SipHash-2-4.
### :param k0: The first 64-bit key word.
### :param k1: The second 64-bit key word.
### :returns: The resulting `U64` value.
routine S64.$secure_hash(k0: U64, k1: U64) -> U64
  return __secure_hash_u64(v: reinterpret_bits[S64, U64](me), k0: k0, k1: k1)
