# Wrapping Arithmetic (+%, -%, *%)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$add_wrap(you: S64) -> S64
  return add[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$sub_wrap(you: S64) -> S64
  return sub[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$mul_wrap(you: S64) -> S64
  return mul[S64](me, you)

# ============================================================================
# Unchecked Arithmetic (+!, -!, *!, //!, %!)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$add_unchecked(you: S64) -> S64
  return signed_add_exact[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$sub_unchecked(you: S64) -> S64
  return signed_sub_exact[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$mul_unchecked(you: S64) -> S64
  return signed_mul_exact[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$floordiv_unchecked(you: S64) -> S64
  var quotient = signed_div[S64](me, you)
  var remainder = signed_rem[S64](me, you)
  if remainder < 0_s64
    if you > 0_s64
      return quotient - 1_s64
    return quotient + 1_s64
  return quotient

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$mod_unchecked(you: S64) -> S64
  var remainder = signed_rem[S64](me, you)
  if remainder < 0_s64
    if you > 0_s64
      return remainder + you
    return remainder - you
  return remainder

# ============================================================================
# Clamping Arithmetic (+^, -^, *^)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$add_clamp(you: S64) -> S64
  return signed_add_sat[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$sub_clamp(you: S64) -> S64
  return signed_sub_sat[S64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S64` value.
routine S64.$mul_clamp(you: S64) -> S64
  var wide = mul[S128](sign_extend[S64, S128](me), sign_extend[S64, S128](you))
  if signed_gt[S128](wide, 9223372036854775807_s128)
    return S64_MAX
  if signed_lt[S128](wide, -9223372036854775808_s128)
    return S64_MIN
  return int_truncate[S128, S64](wide)

# ============================================================================
# Power Operations (**)
# ============================================================================

### Returns the power result and whether it overflowed.
### :param exp: The exponent value.
### :returns: The resulting `(S64, Bool)` value.
### :throws: May throw {IndeterminateResultError}.
routine S64.pow_with_overflow!(exp: S64) -> (S64, Bool)
  var result: S64 = 1
  var base: S64 = me
  var e: S64 = exp
  var overflow = false
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0
    return NegativeExponentError(exp)
  while e > 0
    if (e & 1) == 1
      var mul_result = result.mul_with_overflow(base)
      result = mul_result.item0
      overflow = overflow or mul_result.item1
    e = e >> 1_u32
    if e > 0
      var square_result = base.mul_with_overflow(base)
      base = square_result.item0
      overflow = overflow or square_result.item1
  return (result, overflow)

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S64` value.
### :throws: May throw {IndeterminateResultError}.
routine S64.$pow!(exp: S64) -> S64
  var result = me.pow_with_overflow!(exp)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S64` value.
### :throws: May throw {IndeterminateResultError}.
routine S64.$pow_wrap!(exp: S64) -> S64
  var result: S64 = 1
  var base: S64 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0_s64
    return NegativeExponentError(exp)
  while e > 0
    if (e & 1) == 1
      result = result.$mul_wrap(base)
    e = e >> 1_u32
    if e > 0
      base = base.$mul_wrap(base)
  return result

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S64` value.
### :throws: May throw {IndeterminateResultError}.
routine S64.$pow_clamp!(exp: S64) -> S64
  var result: S64 = 1
  var base: S64 = me
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0
    return NegativeExponentError(exp)
  while exp > 0
    if (exp & 1) == 1
      result = result.$mul_clamp(base)
    exp = exp >> 1_u32
    if exp > 0
      base = base.$mul_clamp(base)
  return result

