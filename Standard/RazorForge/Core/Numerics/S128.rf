# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$add_wrap(you: S128) -> S128
  return add[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$sub_wrap(you: S128) -> S128
  return sub[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mul_wrap(you: S128) -> S128
  return mul[S128](me, you)

# ============================================================================
# Unchecked Arithmetic (+!, -!, *!, //!, %!)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$add_unchecked(you: S128) -> S128
  return add_nsw[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$sub_unchecked(you: S128) -> S128
  return sub_nsw[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mul_unchecked(you: S128) -> S128
  return mul_nsw[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$floordiv_unchecked(you: S128) -> S128
  var quotient = sdiv[S128](me, you)
  var remainder = srem[S128](me, you)
  if remainder < 0_s128
    if you > 0_s128
      return quotient - 1_s128
    return quotient + 1_s128
  return quotient

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mod_unchecked(you: S128) -> S128
  var remainder = srem[S128](me, you)
  if remainder < 0_s128
    if you > 0_s128
      return remainder + you
    return remainder - you
  return remainder

# ============================================================================
# Clamping Arithmetic (+^, -^, *^)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$add_clamp(you: S128) -> S128
  return sadd_sat[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$sub_clamp(you: S128) -> S128
  return ssub_sat[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mul_clamp(you: S128) -> S128
  # Can't widen to 256-bit, use division-based overflow check
  if icmp_eq[S128](me, 0_s128) or icmp_eq[S128](you, 0_s128)
    return 0_s128
  var result = mul[S128](me, you)
  if icmp_ne[S128](sdiv[S128](result, me), you)
    # Overflow: clamp to MAX or MIN based on result sign
    var same_sign = icmp_eq[Bool](icmp_sgt[S128](me, 0_s128), icmp_sgt[S128](you, 0_s128))
    if same_sign
      return S128_MAX
    return S128_MIN
  return result

# ============================================================================
# Power Operations (**)
# ============================================================================

### Returns the power result and whether it overflowed.
### :param exp: The exponent value.
### :returns: The resulting `(S128, Bool)` value.
### :throws: May throw {IndeterminateResultError}.
routine S128.pow_with_overflow!(exp: S128) -> (S128, Bool)
  var result: S128 = 1
  var base: S128 = me
  var e: U32 = exp
  var overflow = false
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0
    return NegativeExponentError(exp)
  while e > 0
    if (e & 1) == 1
      var mul_result = result.mul_with_overflow(base)
      result = mul_result.item0
      overflow = overflow or mul_result.item1
    e = e >> 1_u32
    if e > 0
      var square_result = base.mul_with_overflow(base)
      base = square_result.item0
      overflow = overflow or square_result.item1
  return (result, overflow)

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S128` value.
### :throws: May throw {IndeterminateResultError}.
routine S128.$pow!(exp: S128) -> S128
  var result = me.pow_with_overflow!(exp)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S128` value.
### :throws: May throw {IndeterminateResultError}.
routine S128.$pow_wrap!(exp: S128) -> S128
  var result: S128 = 1
  var base: S128 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0_s128
    return NegativeExponentError(exp)
  while e > 0
    if (e & 1) == 1
      result = result.$mul_wrap(base)
    e = e >> 1_u32
    if e > 0
      base = base.$mul_wrap(base)
  return result

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `S128` value.
### :throws: May throw {IndeterminateResultError}.
routine S128.$pow_clamp!(exp: S128) -> S128
  var result: S128 = 1
  var base: S128 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  if exp < 0
    return NegativeExponentError(exp)
  while e > 0
    if (e & 1) == 1
      result = result.$mul_clamp(base)
    e = e >> 1_u32
    if e > 0
      base = base.$mul_clamp(base)
  return result

