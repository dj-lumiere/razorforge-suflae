### :param bits: The encoded bit pattern.
### :returns: The resulting `S128` value.
routine S128.$ashl(bits: U32) -> S128
  return shl[S128](me, S128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S128` value.
routine S128.$ashr(bits: U32) -> S128
  return ashr[S128](me, S128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S128` value.
routine S128.$lshl(bits: U32) -> S128
  return shl[S128](me, S128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `S128` value.
routine S128.$lshr(bits: U32) -> S128
  return lshr[S128](me, S128(bits))

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine S128.$eq(you: S128) -> Bool
  return icmp_eq[S128](me, you)

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine S128.$cmp(you: S128) -> ComparisonSign
  if icmp_slt[S128](me, you)
    return ME_SMALL
  if icmp_sgt[S128](me, you)
    return ME_LARGE
  return SAME

# ============================================================================
# Math Operations
# ============================================================================

### Returns the absolute value.
### :returns: The resulting `S128` value.
routine S128.abs() -> S128
  return abs[S128](me)

### Returns the result of `min`.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.min(you: S128) -> S128
  return if me <= you then me else you

### Returns the result of `max`.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.max(you: S128) -> S128
  return if me >= you then me else you

### Returns the result of `clamp`.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :returns: The resulting `S128` value.
routine S128.clamp(min_val: S128, max_val: S128) -> S128
  return me.min(max_val).max(min_val)

# ============================================================================
# Bit Manipulation
# ============================================================================

### Returns the number of stored values.
### :returns: The resulting `S128` value.
routine S128.count_ones() -> S128
  return ctpop[S128](me)

### Returns the number of stored values.
### :returns: The resulting `S128` value.
routine S128.count_zeros() -> S128
  return 128_s128 -% me.count_ones()

### Returns the result of `leading zeros`.
### :returns: The resulting `S128` value.
routine S128.leading_zeros() -> S128
  return ctlz[S128](me)

### Returns the result of `trailing zeros`.
### :returns: The resulting `S128` value.
routine S128.trailing_zeros() -> S128
  return cttz[S128](me)

### Returns the result of `leading ones`.
### :returns: The resulting `S128` value.
routine S128.leading_ones() -> S128
  return me.$bitnot().leading_zeros()

### Returns the result of `trailing ones`.
### :returns: The resulting `S128` value.
routine S128.trailing_ones() -> S128
  return me.$bitnot().trailing_zeros()

### Returns the result of `reverse bits`.
### :returns: The resulting `S128` value.
routine S128.reverse_bits() -> S128
  return bitreverse[S128](me)

### Returns the result of `swap bytes`.
### :returns: The resulting `S128` value.
routine S128.swap_bytes() -> S128
  return bswap[S128](me)

# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is positive.
### :returns: The resulting `Bool` value.
routine S128.is_positive() -> Bool
  return me > 0_s128

### Returns true if this value is negative.
### :returns: The resulting `Bool` value.
routine S128.is_negative() -> Bool
  return me < 0_s128

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine S128.is_zero() -> Bool
  return me == 0_s128

### Returns true if this value is even.
### :returns: The resulting `Bool` value.
routine S128.is_even() -> Bool
  var result = bit_and[S128](me, 1_s128)
  return icmp_eq[S128](result, 0_s128)

### Returns true if this value is odd.
### :returns: The resulting `Bool` value.
routine S128.is_odd() -> Bool
  return not me.is_even()

### Returns the result of `signum`.
### :returns: The resulting `S128` value.
routine S128.signum() -> S128
  return when
    me > 0_s128 => 1_s128
    me < 0_s128 => -1_s128
    else => 0_s128

# ============================================================================
# Text Representation and Parsing
# ============================================================================

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine S128.$represent() -> Text
  if me == 0s128
    return "0"
  if me > 0s128
    return U128(me).$represent()
  return "-" + U128(0u128 -% U128(me)).$represent()

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine S128.$diagnose() -> Text
  return "S128(" + me.$represent() + ")"

### Implements the wired routine behavior for this value.
### :param from_text: The `from_text` value.
### :returns: The resulting `S128` value.
### :throws: May throw {InvalidValueError}.
routine S128.$create!(from_text: Text) -> S128
  if from_text.count() == 0u64
    throw InvalidValueError(input: from_text, target: "S128")
  var start = 0u64
  var negative = false
  var first = from_text[0u64]
  if first == Character(0x002Du32)
    negative = true
    start = 1u64
  elseif first == Character(0x002Bu32)
    start = 1u64
  if start >= from_text.count()
    throw InvalidValueError(input: from_text, target: "S128")
  var result = 0u128
  var i = start
  while i < from_text.count()
    var ch = from_text[i]
    if ch.is_numeric()
      result = result * 10u128 + U128(ch.digit_value())
    else
      throw InvalidValueError(input: from_text, target: "S128")
    i = i + 1u64
  if negative
    return S128(0u128 - result)
  return S128(result)
