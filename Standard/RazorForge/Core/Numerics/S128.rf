### :returns: The resulting `S128` value.
routine S128.$create!(from: D128) -> S128
  return from.S64!().S128()

# ============================================================================
# Arithmetic Operations (trapping on overflow by default)
# ============================================================================

### Returns the sum and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(S128, Bool)` value.
routine S128.add_with_overflow(you: S128) -> (S128, Bool)
  return sadd_with_overflow[S128](me, you)

### Returns the difference and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(S128, Bool)` value.
routine S128.sub_with_overflow(you: S128) -> (S128, Bool)
  return ssub_with_overflow[S128](me, you)

### Returns the product and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(S128, Bool)` value.
routine S128.mul_with_overflow(you: S128) -> (S128, Bool)
  return smul_with_overflow[S128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$add!(you: S128) -> S128
  var result = me.add_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$sub!(you: S128) -> S128
  var result = me.sub_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mul!(you: S128) -> S128
  var result = me.mul_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
### :throws: May throw {DivisionByZeroError}.
routine S128.$floordiv!(you: S128) -> S128
  if you == 0
    throw DivisionByZeroError()
  if me == S128_MIN and you == -1_s128
    throw IntegerOverflowError()
  var quotient = sdiv[S128](me, you)
  var remainder = srem[S128](me, you)
  if remainder < 0_s128
    if you > 0_s128
      return quotient - 1_s128
    return quotient + 1_s128
  return quotient

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `S128` value.
routine S128.$mod!(you: S128) -> S128
  if you == 0
    throw DivisionByZeroError()
  var remainder = srem[S128](me, you)
  if remainder < 0_s128
    if you > 0_s128
      return remainder + you
    return remainder - you
  return remainder

### Implements the wired routine behavior for this value.
### :returns: The resulting `S128` value.
routine S128.$neg!() -> S128
  return sub[S128](0, me)

