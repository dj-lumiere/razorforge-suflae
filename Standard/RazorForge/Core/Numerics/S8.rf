# RazorForge S8 (signed 8-bit integer) native type implementation
# Maps directly to LLVM i8 type using compiler intrinsics
module Core
# Core S8 type definition - maps to LLVM i8

### Defines the record `S8`.
@llvm("i8")
record S8 obeys SignedIntegral, Ordered, ConstCompatible
  pass

# Constants for S8 limits
preset S8_MIN: S8 = -128_s8
preset S8_MAX: S8 = 127_s8
preset S8_ZERO: S8 = 0_s8
preset S8_ONE: S8 = 1_s8

# ============================================================================
# Creators
# ============================================================================

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
routine S8.$create(from: S8) -> S8
  return from

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: S16) -> S8
  if not (S8_MIN <= from <= S8_MAX)
    throw IntegerOverflowError()
  return int_truncate[S16, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: S32) -> S8
  if not (S8_MIN <= from <= S8_MAX)
    throw IntegerOverflowError()
  return int_truncate[S32, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: S64) -> S8
  if not (S8_MIN <= from <= S8_MAX)
    throw IntegerOverflowError()
  return int_truncate[S64, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: S128) -> S8
  if not (S8_MIN <= from <= S8_MAX)
    throw IntegerOverflowError()
  return int_truncate[S128, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: U8) -> S8
  if from > 127_u8
    throw IntegerOverflowError()
  return reinterpret_bits[U8, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: U16) -> S8
  if from > 127_u16
    throw IntegerOverflowError()
  return int_truncate[U16, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: U32) -> S8
  if from > 127_u32
    throw IntegerOverflowError()
  return int_truncate[U32, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: U64) -> S8
  if from > 127_u64
    throw IntegerOverflowError()
  return int_truncate[U64, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
### :throws: May throw {IntegerOverflowError}.
routine S8.$create!(from: U128) -> S8
  if from > 127_u128
    throw IntegerOverflowError()
  return int_truncate[U128, S8](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
routine S8.$create!(from: F16) -> S8
  return from.S32!().S8!()

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `S8` value.
routine S8.$create!(from: F32) -> S8
  return from.S32!().S8!()

