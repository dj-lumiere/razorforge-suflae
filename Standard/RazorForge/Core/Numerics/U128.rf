routine U128.$add_unchecked(you: U128) -> U128
  return unsigned_add_exact[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$sub_unchecked(you: U128) -> U128
  return unsigned_sub_exact[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$mul_unchecked(you: U128) -> U128
  return unsigned_mul_exact[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$floordiv_unchecked(you: U128) -> U128
  return unsigned_div[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$mod_unchecked(you: U128) -> U128
  return unsigned_rem[U128](me, you)

# ============================================================================
# Clamping Arithmetic (+^, -^, *^)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$add_clamp(you: U128) -> U128
  return unsigned_add_sat[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$sub_clamp(you: U128) -> U128
  return unsigned_sub_sat[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$mul_clamp(you: U128) -> U128
  # Can't widen to 256-bit, use division-based overflow check
  if int_eq[U128](me, 0_u128) or int_eq[U128](you, 0_u128)
    return 0_u128
  var result = mul[U128](me, you)
  if int_ne[U128](unsigned_div[U128](result, me), you)
    return U128_MAX
  return result

# ============================================================================
# Power Operations (**)
# ============================================================================

### Returns the power result and whether it overflowed.
### :param exp: The exponent value.
### :returns: The resulting `(U128, Bool)` value.
### :throws: May throw {IndeterminateResultError}.
routine U128.pow_with_overflow!(exp: U128) -> (U128, Bool)
  var result: U128 = 1
  var base: U128 = me
  var e: U32 = exp
  var overflow = false
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      var mul_result = result.mul_with_overflow(base)
      result = mul_result.item0
      overflow = overflow or mul_result.item1
    e = e >> 1_u32
    if e > 0
      var square_result = base.mul_with_overflow(base)
      base = square_result.item0
      overflow = overflow or square_result.item1
  return (result, overflow)

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U128` value.
### :throws: May throw {IndeterminateResultError}.
routine U128.$pow!(exp: U128) -> U128
  var result = me.pow_with_overflow!(exp)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U128` value.
### :throws: May throw {IndeterminateResultError}.
routine U128.$pow_wrap!(exp: U128) -> U128
  var result: U128 = 1
  var base: U128 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      result = result.$mul_wrap(base)
    e = e >> 1_u32
    if e > 0
      base = base.$mul_wrap(base)
  return result

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U128` value.
### :throws: May throw {IndeterminateResultError}.
routine U128.$pow_clamp!(exp: U128) -> U128
  var result: U128 = 1
  var base: U128 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      result = result.$mul_clamp(base)
    base = base.$mul_clamp(base)
    e = e >> 1_u32
  return result

