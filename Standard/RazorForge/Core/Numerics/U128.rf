# ============================================================================
# Arithmetic Operations (trapping on overflow by default)
# ============================================================================

### Returns the sum and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U128, Bool)` value.
routine U128.add_with_overflow(you: U128) -> (U128, Bool)
  return unsigned_add_checked[U128](me, you)

### Returns the difference and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U128, Bool)` value.
routine U128.sub_with_overflow(you: U128) -> (U128, Bool)
  return unsigned_sub_checked[U128](me, you)

### Returns the product and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U128, Bool)` value.
routine U128.mul_with_overflow(you: U128) -> (U128, Bool)
  return unsigned_mul_checked[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$add!(you: U128) -> U128
  var result = me.add_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$sub!(you: U128) -> U128
  var result = me.sub_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$mul!(you: U128) -> U128
  var result = me.mul_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
### :throws: May throw {DivisionByZeroError}.
routine U128.$floordiv!(you: U128) -> U128
  if you == 0
    throw DivisionByZeroError()
  return unsigned_div[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$mod!(you: U128) -> U128
  return unsigned_rem[U128](me, you)

