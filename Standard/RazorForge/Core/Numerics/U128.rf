### :param from: The source value to convert.
### :returns: The resulting `U128` value.
### :throws: May throw {IntegerOverflowError}.
routine U128.$create!(from: S64) -> U128
  if from < 0_s64
    throw IntegerOverflowError()
  return sign_extend[S64, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
### :throws: May throw {IntegerOverflowError}.
routine U128.$create!(from: S128) -> U128
  if from < 0_s128
    throw IntegerOverflowError()
  return reinterpret_bits[S128, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
routine U128.$create!(from: U8) -> U128
  return zero_extend[U8, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
routine U128.$create!(from: U16) -> U128
  return zero_extend[U16, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
routine U128.$create!(from: U32) -> U128
  return zero_extend[U32, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
routine U128.$create!(from: U64) -> U128
  return zero_extend[U64, U128](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
routine U128.$create(from: U128) -> U128
  return from

