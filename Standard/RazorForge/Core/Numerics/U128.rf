### :param from: The source value to convert.
### :returns: The resulting `U128` value.
### :throws: May throw {IntegerOverflowError}.
routine U128.$create!(from: S32) -> U128
  if from < 0_s32
    throw IntegerOverflowError()
  return sign_extend[S32, U128](from)

