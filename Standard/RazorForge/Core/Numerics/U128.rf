### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$bitand(you: U128) -> U128
  return bit_and[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$bitor(you: U128) -> U128
  return bit_or[U128](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.$bitxor(you: U128) -> U128
  return bit_xor[U128](me, you)

### Implements the wired routine behavior for this value.
### :returns: The resulting `U128` value.
routine U128.$bitnot() -> U128
  return bit_xor[U128](me, -1)

# ============================================================================
# Shift Operations (<<, <<?>, >>, <<<, >>>)
# For unsigned types, arithmetic and logical shifts behave identically
# ============================================================================

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U128` value.
routine U128.$ashl(bits: U32) -> U128
  return shift_left[U128](me, U128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U128` value.
routine U128.$ashr(bits: U32) -> U128
  return shift_right_unsigned[U128](me, U128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U128` value.
routine U128.$lshl(bits: U32) -> U128
  return shift_left[U128](me, U128(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U128` value.
routine U128.$lshr(bits: U32) -> U128
  return shift_right_unsigned[U128](me, U128(bits))

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine U128.$eq(you: U128) -> Bool
  return int_eq[U128](me, you)

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine U128.$cmp(you: U128) -> ComparisonSign
  if unsigned_lt[U128](me, you)
    return ME_SMALL
  if unsigned_gt[U128](me, you)
    return ME_LARGE
  return SAME

# ============================================================================
# Math Operations
# ============================================================================

### Returns the result of `min`.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.min(you: U128) -> U128
  return if me <= you then me else you

### Returns the result of `max`.
### :param you: The other value to compare against.
### :returns: The resulting `U128` value.
routine U128.max(you: U128) -> U128
  return if me >= you then me else you

### Returns the result of `clamp`.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :returns: The resulting `U128` value.
routine U128.clamp(min_val: U128, max_val: U128) -> U128
  return me.min(max_val).max(min_val)

# ============================================================================
# Bit Manipulation
# ============================================================================

### Returns the number of stored values.
### :returns: The resulting `U128` value.
routine U128.count_ones() -> U128
  return count_ones[U128](me)

### Returns the number of stored values.
### :returns: The resulting `U128` value.
routine U128.count_zeros() -> U128
  return 128_u128 -% me.count_ones()

### Returns the result of `leading zeros`.
### :returns: The resulting `U128` value.
routine U128.leading_zeros() -> U128
  return leading_zeros[U128](me)

### Returns the result of `trailing zeros`.
### :returns: The resulting `U128` value.
routine U128.trailing_zeros() -> U128
  return trailing_zeros[U128](me)

### Returns the result of `leading ones`.
### :returns: The resulting `U128` value.
routine U128.leading_ones() -> U128
  return me.$bitnot().leading_zeros()

### Returns the result of `trailing ones`.
### :returns: The resulting `U128` value.
routine U128.trailing_ones() -> U128
  return me.$bitnot().trailing_zeros()

### Returns the result of `reverse bits`.
### :returns: The resulting `U128` value.
routine U128.reverse_bits() -> U128
  return reverse_bits[U128](me)

### Returns the result of `swap bytes`.
### :returns: The resulting `U128` value.
routine U128.swap_bytes() -> U128
  return byte_swap[U128](me)

### Returns true if this value is power of two.
### :returns: The resulting `Bool` value.
routine U128.is_power_of_two() -> Bool
  return me != 0_u128 and (me & (me - 1_u128)) == 0_u128

# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine U128.is_zero() -> Bool
  return me == 0_u128

### Returns true if this value is even.
### :returns: The resulting `Bool` value.
routine U128.is_even() -> Bool
  var result = bit_and[U128](me, 1_u128)
  return int_eq[U128](result, 0_u128)

### Returns true if this value is odd.
### :returns: The resulting `Bool` value.
routine U128.is_odd() -> Bool
  return not me.is_even()

### Returns the result of `high64`.
### :returns: The resulting `U64` value.
routine U128.high64() -> U64
  var shifted = shift_right_unsigned[U128](me, 64_u32)
  return int_truncate[U128, U64](shifted)

### Returns the result of `low64`.
### :returns: The resulting `U64` value.
routine U128.low64() -> U64
  return int_truncate[U128, U64](me)

# ============================================================================
# Text Representation and Parsing
# ============================================================================

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine U128.$represent() -> Text
  if me == 0u128
    return "0"
  var digits = List[Character]()
  var remaining = me
  while remaining > 0u128
    var digit = U8(unsigned_rem[U128](remaining, 10u128))
    remaining = unsigned_div[U128](remaining, 10u128)
    digits.add_first(Character(0x0030u32 + U32(digit)))
  return Text(from_list: digits)

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine U128.$diagnose() -> Text
  return "U128(" + me.$represent() + ")"

### Implements the wired routine behavior for this value.
### :param from_text: The `from_text` value.
### :returns: The resulting `U128` value.
### :throws: May throw {InvalidValueError}.
routine U128.$create!(from_text: Text) -> U128
  if from_text.count() == 0u64
    throw InvalidValueError(input: from_text, target: "U128")
  var result = 0u128
  var i = 0u64
  while i < from_text.count()
    var ch = from_text[i]
    if ch.is_numeric()
      result = result * 10u128 + U128(ch.digit_value())
    else
      throw InvalidValueError(input: from_text, target: "U128")
    i = i + 1u64
  return result

# ============================================================================
# Hashing
# ============================================================================

### Returns a hash of this value.
### :returns: The resulting `U64` value.
routine U128.$hash() -> U64
  return __hash_u128(v: me)

### Returns a keyed hash of this value using SipHash-2-4.
### :param k0: The first 64-bit key word.
### :param k1: The second 64-bit key word.
### :returns: The resulting `U64` value.
routine U128.$secure_hash(k0: U64, k1: U64) -> U64
  return __secure_hash_u128(v: me, k0: k0, k1: k1)
