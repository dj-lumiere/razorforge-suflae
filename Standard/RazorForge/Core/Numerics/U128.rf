# RazorForge U128 (unsigned 128-bit integer) native type implementation
# Maps directly to LLVM i128 type using compiler intrinsics
module Core
### Defines the record `U128`.
@llvm("i128")
record U128 obeys UnsignedIntegral, Ordered, ConstCompatible
  pass

# Constants for U128 limits
preset U128_MIN: U128 = 0_u128
preset U128_MAX: U128 = 340282366920938463463374607431768211455_u128
preset U128_ZERO: U128 = 0_u128
preset U128_ONE: U128 = 1_u128

# ============================================================================
# Creators
# ============================================================================

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
### :throws: May throw {IntegerOverflowError}.
routine U128.$create!(from: S8) -> U128
  if from < 0_s8
    throw IntegerOverflowError()
  return sign_extend[S8, U128](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U128` value.
### :throws: May throw {IntegerOverflowError}.
routine U128.$create!(from: S16) -> U128
  if from < 0_s16
    throw IntegerOverflowError()
  return sign_extend[S16, U128](from)

