# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$add_unchecked(you: U64) -> U64
  return add_nuw[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$sub_unchecked(you: U64) -> U64
  return sub_nuw[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$mul_unchecked(you: U64) -> U64
  return mul_nuw[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$floordiv_unchecked(you: U64) -> U64
  return udiv[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$mod_unchecked(you: U64) -> U64
  return urem[U64](me, you)

# ============================================================================
# Clamping Arithmetic (+^, -^, *^)
# ============================================================================

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$add_clamp(you: U64) -> U64
  return uadd_sat[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$sub_clamp(you: U64) -> U64
  return usub_sat[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$mul_clamp(you: U64) -> U64
  var wide = mul[U128](zext[U64, U128](me), zext[U64, U128](you))
  if icmp_ugt[U128](wide, 18446744073709551615_u128)
    return U64_MAX
  return trunc[U128, U64](wide)

# ============================================================================
# Power Operations (**)
# ============================================================================

### Returns the power result and whether it overflowed.
### :param exp: The exponent value.
### :returns: The resulting `(U64, Bool)` value.
### :throws: May throw {IndeterminateResultError}.
routine U64.pow_with_overflow!(exp: U64) -> (U64, Bool)
  var result: U64 = 1
  var base: U64 = me
  var e: U32 = exp
  var overflow = false
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      var mul_result = result.mul_with_overflow(base)
      result = mul_result.item0
      overflow = overflow or mul_result.item1
    e = e >> 1_u32
    if e > 0
      var square_result = base.mul_with_overflow(base)
      base = square_result.item0
      overflow = overflow or square_result.item1
  return (result, overflow)

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U64` value.
### :throws: May throw {IndeterminateResultError}.
routine U64.$pow!(exp: U64) -> U64
  var result = me.pow_with_overflow!(exp)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U64` value.
### :throws: May throw {IndeterminateResultError}.
routine U64.$pow_wrap!(exp: U64) -> U64
  var result: U64 = 1
  var base: U64 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      result = result.$mul_wrap(base)
    e = e >> 1_u32
    if e > 0
      base = base.$mul_wrap(base)
  return result

### Implements the wired routine behavior for this value.
### :param exp: The exponent value.
### :returns: The resulting `U64` value.
### :throws: May throw {IndeterminateResultError}.
routine U64.$pow_clamp!(exp: U64) -> U64
  var result: U64 = 1
  var base: U64 = me
  var e: U32 = exp
  if me == 0 and exp == 0
    throw IndeterminateResultError()
  while e > 0
    if (e & 1) == 1
      result = result.$mul_clamp(base)
    base = base.$mul_clamp(base)
    e = e >> 1_u32
  return result

