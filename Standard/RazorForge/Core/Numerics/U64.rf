### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$bitand(you: U64) -> U64
  return bit_and[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$bitor(you: U64) -> U64
  return bit_or[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$bitxor(you: U64) -> U64
  return xor[U64](me, you)

### Implements the wired routine behavior for this value.
### :returns: The resulting `U64` value.
routine U64.$bitnot() -> U64
  return xor[U64](me, -1)

# ============================================================================
# Shift Operations (<<, <<?>, >>, <<<, >>>)
# For unsigned types, arithmetic and logical shifts behave identically
# ============================================================================

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.$ashl(bits: U32) -> U64
  return shl[U64](me, U64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.$ashr(bits: U32) -> U64
  return lshr[U64](me, U64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.$lshl(bits: U32) -> U64
  return shl[U64](me, U64(bits))

### Implements the wired routine behavior for this value.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.$lshr(bits: U32) -> U64
  return lshr[U64](me, U64(bits))

# ============================================================================
# Comparison Operations
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine U64.$eq(you: U64) -> Bool
  return icmp_eq[U64](me, you)

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine U64.$cmp(you: U64) -> ComparisonSign
  if icmp_ult[U64](me, you)
    return ME_SMALL
  if icmp_ugt[U64](me, you)
    return ME_LARGE
  return SAME

# ============================================================================
# Math Operations
# ============================================================================

### Returns the result of `min`.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.min(you: U64) -> U64
  return if me <= you then me else you

### Returns the result of `max`.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.max(you: U64) -> U64
  return if me >= you then me else you

### Returns the result of `clamp`.
### :param min_val: The `min_val` value.
### :param max_val: The `max_val` value.
### :returns: The resulting `U64` value.
routine U64.clamp(min_val: U64, max_val: U64) -> U64
  return me.min(max_val).max(min_val)

# ============================================================================
# Bit Manipulation
# ============================================================================

### Returns the number of stored values.
### :returns: The resulting `U64` value.
routine U64.count_ones() -> U64
  return ctpop[U64](me)

### Returns the number of stored values.
### :returns: The resulting `U64` value.
routine U64.count_zeros() -> U64
  return 64_u64 -% me.count_ones()

### Returns the result of `leading zeros`.
### :returns: The resulting `U64` value.
routine U64.leading_zeros() -> U64
  return ctlz[U64](me)

### Returns the result of `trailing zeros`.
### :returns: The resulting `U64` value.
routine U64.trailing_zeros() -> U64
  return cttz[U64](me)

### Returns the result of `leading ones`.
### :returns: The resulting `U64` value.
routine U64.leading_ones() -> U64
  return me.$bitnot().leading_zeros()

### Returns the result of `trailing ones`.
### :returns: The resulting `U64` value.
routine U64.trailing_ones() -> U64
  return me.$bitnot().trailing_zeros()

### Returns the result of `reverse bits`.
### :returns: The resulting `U64` value.
routine U64.reverse_bits() -> U64
  return bitreverse[U64](me)

### Returns the result of `swap bytes`.
### :returns: The resulting `U64` value.
routine U64.swap_bytes() -> U64
  return bswap[U64](me)

### Returns true if this value is power of two.
### :returns: The resulting `Bool` value.
routine U64.is_power_of_two() -> Bool
  return me != 0_u64 and (me & (me -% 1_u64)) == 0_u64

### Returns the result of `rotate left`.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.rotate_left(bits: U32) -> U64
  var left = shl[U64](me, bits)
  var right = lshr[U64](me, 64_u32 -% bits)
  return bit_or[U64](left, right)

### Returns the result of `rotate right`.
### :param bits: The encoded bit pattern.
### :returns: The resulting `U64` value.
routine U64.rotate_right(bits: U32) -> U64
  var right = lshr[U64](me, bits)
  var left = shl[U64](me, 64_u32 -% bits)
  return bit_or[U64](right, left)

# ============================================================================
# Utility Methods
# ============================================================================

### Returns true if this value is zero.
### :returns: The resulting `Bool` value.
routine U64.is_zero() -> Bool
  return me == 0_u64

### Returns true if this value is even.
### :returns: The resulting `Bool` value.
routine U64.is_even() -> Bool
  var result = bit_and[U64](me, 1_u64)
  return icmp_eq[U64](result, 0_u64)

### Returns true if this value is odd.
### :returns: The resulting `Bool` value.
routine U64.is_odd() -> Bool
  return not me.is_even()

### Returns this value as a `ByteSize`.
### :returns: The resulting `ByteSize` value.
routine U64.bytes() -> ByteSize
  return ByteSize(me)

# ============================================================================
# Text Representation and Parsing
# ============================================================================

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine U64.$represent() -> Text
  if me == 0u64
    return "0"
  var digits = List[Character]()
  var remaining = me
  while remaining > 0u64
    var digit = U8(urem[U64](remaining, 10u64))
    remaining = udiv[U64](remaining, 10u64)
    digits.add_first(Character(0x0030u32 + U32(digit)))
  return Text(from_list: digits)

### Returns the textual representation of this value.
### :returns: The resulting `Text` value.
routine U64.$diagnose() -> Text
  return "U64(" + me.$represent() + ")"

### Implements the wired routine behavior for this value.
### :param from_text: The `from_text` value.
### :returns: The resulting `U64` value.
### :throws: May throw {InvalidValueError}.
routine U64.$create!(from_text: Text) -> U64
  if from_text.count() == 0u64
    throw InvalidValueError(input: from_text, target: "U64")
  var result = 0u64
  var i = 0u64
  while i < from_text.count()
    var ch = from_text[i]
    if ch.is_numeric()
      result = result * 10u64 + U64(ch.digit_value())
    else
      throw InvalidValueError(input: from_text, target: "U64")
    i = i + 1u64
  return result

# ============================================================================
# Hashing
# ============================================================================

### Returns a hash of this value.
### :returns: The resulting `U64` value.
routine U64.$hash() -> U64
  return __hash_leaf(v: me)

### Returns a keyed hash of this value using SipHash-2-4.
### :param k0: The first 64-bit key word.
### :param k1: The second 64-bit key word.
### :returns: The resulting `U64` value.
routine U64.$secure_hash(k0: U64, k1: U64) -> U64
  return __secure_hash_u64(v: me, k0: k0, k1: k1)
