# RazorForge U64 (unsigned 64-bit integer) native type implementation
# Maps directly to LLVM i64 type using compiler intrinsics
module Core
### Defines the record `U64`.
@llvm("i64")
record U64 obeys UnsignedIntegral, Ordered, ConstCompatible
  pass

# Constants for U64 limits
preset U64_MIN: U64 = 0_u64
preset U64_MAX: U64 = 18_446_744_073_709_551_615_u64
preset U64_ZERO: U64 = 0_u64
preset U64_ONE: U64 = 1_u64

# ============================================================================
# Creators
# ============================================================================

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: S8) -> U64
  if from < 0_s8
    throw IntegerOverflowError()
  return sext[S8, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: S16) -> U64
  if from < 0_s16
    throw IntegerOverflowError()
  return sext[S16, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: S32) -> U64
  if from < 0_s32
    throw IntegerOverflowError()
  return sext[S32, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: S64) -> U64
  if from < 0_s64
    throw IntegerOverflowError()
  return bitcast[S64, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: S128) -> U64
  if not (0_s128 <= from <= 18446744073709551615_s128)
    throw IntegerOverflowError()
  return trunc[S128, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: U8) -> U64
  return zext[U8, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: U16) -> U64
  return zext[U16, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: U32) -> U64
  return zext[U32, U64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create(from: U64) -> U64
  return from

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
### :throws: May throw {IntegerOverflowError}.
routine U64.$create!(from: U128) -> U64
  if from > 18446744073709551615_u128
    throw IntegerOverflowError()
  return trunc[U128, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: F16) -> U64
  return from.F32().U64!()

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: F32) -> U64
  return fptoui[F32, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: F64) -> U64
  return fptoui[F64, U64](from)

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: F128) -> U64
  return from.F64!().U64!()

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: D32) -> U64
  return from.S64!().U64!()

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: D64) -> U64
  return from.S64!().U64!()

### Implements the wired routine behavior for this value.
### :param from: The source value to convert.
### :returns: The resulting `U64` value.
routine U64.$create!(from: D128) -> U64
  return from.S64!().U64!()

# ============================================================================
# Arithmetic Operations (trapping on overflow by default)
# ============================================================================

### Returns the sum and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U64, Bool)` value.
routine U64.add_with_overflow(you: U64) -> (U64, Bool)
  return uadd_with_overflow[U64](me, you)

### Returns the difference and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U64, Bool)` value.
routine U64.sub_with_overflow(you: U64) -> (U64, Bool)
  return usub_with_overflow[U64](me, you)

### Returns the product and whether it overflowed.
### :param you: The other value to compare against.
### :returns: The resulting `(U64, Bool)` value.
routine U64.mul_with_overflow(you: U64) -> (U64, Bool)
  return umul_with_overflow[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$add!(you: U64) -> U64
  var result = me.add_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$sub!(you: U64) -> U64
  var result = me.sub_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$mul!(you: U64) -> U64
  var result = me.mul_with_overflow(you)
  if result.item1
    throw IntegerOverflowError()
  return result.item0

### Returns the product of this value and the other value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$mul(you: U64) -> U64
  return me.$mul!(you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
routine U64.$floordiv!(you: U64) -> U64
  if you == 0
    throw DivisionByZeroError()
  return udiv[U64](me, you)

### Implements the wired routine behavior for this value.
### :param you: The other value to compare against.
### :returns: The resulting `U64` value.
### :throws: May throw {DivisionByZeroError}.
routine U64.$mod!(you: U64) -> U64
  if you == 0
    throw DivisionByZeroError()
  return urem[U64](me, you)

