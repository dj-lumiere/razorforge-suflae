# RazorForge F64 (double precision floating point) native type implementation
# Maps directly to LLVM double type using compiler intrinsics
module Core
# Core F64 type definition - maps to LLVM double

### Defines the record `F64`.
@llvm("double")
record F64 obeys Numeric, Ordered
  pass

# IEEE 754 double precision constants
preset F64_EPSILON: F64 = 2.220446049250313e-16_f64
preset F64_MIN: F64 = 2.2250738585072014e-308_f64
preset F64_MAX: F64 = 1.7976931348623157e+308_f64
preset F64_ZERO: F64 = 0.0_f64
preset F64_ONE: F64 = 1.0_f64
preset F64_NAN: F64 = 0.0_f64 / 0.0_f64  # TODO: Proper NaN constant
preset F64_INFINITY: F64 = 1.0_f64 / 0.0_f64  # TODO: Proper infinity constant

# ============================================================================
# Creators
# ============================================================================

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: S8) -> F64
  return sitofp[S8, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: S16) -> F64
  return sitofp[S16, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: S32) -> F64
  return sitofp[S32, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: S64) -> F64
  return sitofp[S64, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: S128) -> F64
  return sitofp[S128, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: U8) -> F64
  return uitofp[U8, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: U16) -> F64
  return uitofp[U16, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: U32) -> F64
  return uitofp[U32, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: U64) -> F64
  return uitofp[U64, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: U128) -> F64
  return uitofp[U128, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: F16) -> F64
  return fpext[F16, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: F32) -> F64
  return fpext[F32, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: F64) -> F64
  return from

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: F128) -> F64
  return fptrunc[F128, F64](from)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: D32) -> F64
  var bits = bitcast[D32, U32](from)
  return rf_d32_to_f64(bits)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: D64) -> F64
  var bits = bitcast[D64, U64](from)
  return rf_d64_to_f64(bits)

### Creates a new instance.
### :param from: The source value to convert.
### :returns: The resulting `F64` value.
routine F64.$create(from: D128) -> F64
  return rf_d128_to_f64(from.low_bits(), from.high_bits())

# ============================================================================
# Arithmetic Operations
# ============================================================================

### Returns the sum of this value and the other value.
### :param you: The other value to compare against.
### :returns: The resulting `F64` value.
routine F64.$add(you: F64) -> F64
  return fadd[F64](me, you)

### Returns the difference between this value and the other value.
### :param you: The other value to compare against.
### :returns: The resulting `F64` value.
routine F64.$sub(you: F64) -> F64
  return fsub[F64](me, you)

### Returns the product of this value and the other value.
### :param you: The other value to compare against.
### :returns: The resulting `F64` value.
routine F64.$mul(you: F64) -> F64
  return fmul[F64](me, you)

### Returns the quotient of this value and the other value.
### :param you: The other value to compare against.
### :returns: The resulting `F64` value.
routine F64.$truediv(you: F64) -> F64
  return fdiv[F64](me, you)

### Returns the negated value.
### :returns: The resulting `F64` value.
routine F64.$neg() -> F64
  return fneg[F64](me)

# ============================================================================
# Comparison Operations (ordered - false if NaN)
# ============================================================================

### Returns whether both values are equal.
### :param you: The other value to compare against.
### :returns: The resulting `Bool` value.
routine F64.$eq(you: F64) -> Bool
  return fcmp_oeq[F64](me, you)

### Compares this value with the other value.
### :param you: The other value to compare against.
### :returns: The resulting `ComparisonSign` value.
routine F64.$cmp(you: F64) -> ComparisonSign
  if fcmp_olt[F64](me, you)
    return ME_SMALL
  if fcmp_ogt[F64](me, you)
    return ME_LARGE
  return SAME

