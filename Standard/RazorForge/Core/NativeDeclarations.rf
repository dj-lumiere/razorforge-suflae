external("C") routine rf_bigint_mod(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_neg(result: Address, a: Address)

# Comparison
external("C") routine rf_bigint_cmp(a: Address, b: Address) -> S32

# Bitwise operations
external("C") routine rf_bigint_and(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_or(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_xor(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_shl(result: Address, a: Address, bits: S32)
external("C") routine rf_bigint_shr(result: Address, a: Address, bits: S32)

# Math operations
external("C") routine rf_bigint_abs(result: Address, a: Address)
external("C") routine rf_bigint_pow(result: Address, base: Address, exp: U32)
external("C") routine rf_bigint_sqrt(result: Address, a: Address)
external("C") routine rf_bigint_gcd(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_lcm(result: Address, a: Address, b: Address)

# Query functions
external("C") routine rf_bigint_is_zero(handle: Address) -> S32
external("C") routine rf_bigint_is_neg(handle: Address) -> S32

