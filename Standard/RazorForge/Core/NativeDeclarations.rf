# ============================================================================
# D128 (Decimal128) - Intel DFP Library
# D128 functions take (low: U64, high: U64) pairs and return D128
# ============================================================================

### Returns the result of `rf d128 from s32`.
### :param value: The value to use.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_from_s32(value: S32) -> D128
### Returns the result of `rf d128 from s64`.
### :param value: The value to use.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_from_s64(value: S64) -> D128
### Returns the result of `rf d128 from u32`.
### :param value: The value to use.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_from_u32(value: U32) -> D128
### Returns the result of `rf d128 from u64`.
### :param value: The value to use.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_from_u64(value: U64) -> D128

