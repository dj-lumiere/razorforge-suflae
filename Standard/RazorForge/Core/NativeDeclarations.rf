external("C") routine rf_console_clear()

# ============================================================================
# Integer (Arbitrary Precision) - LibTomMath
# All functions use opaque handles (Address) to mp_int structures
# ============================================================================

# Lifecycle
external("C") routine rf_bigint_new() -> Address
external("C") routine rf_bigint_clear(handle: Address)
external("C") routine rf_bigint_copy(dest: Address, src: Address)

# Initialization from values
external("C") routine rf_bigint_set_i64(handle: Address, value: S64)
external("C") routine rf_bigint_set_u64(handle: Address, value: U64)
external("C") routine rf_bigint_set_str(handle: Address, str: Address, radix: S32) -> S32

# Extraction to values
external("C") routine rf_bigint_get_i64(handle: Address) -> S64
external("C") routine rf_bigint_get_u64(handle: Address) -> U64
external("C") routine rf_bigint_get_str(handle: Address, radix: S32) -> Address

# Arithmetic (result = op(a, b) or result = op(a))
external("C") routine rf_bigint_add(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_sub(result: Address, a: Address, b: Address)
external("C") routine rf_bigint_mul(result: Address, a: Address, b: Address)
