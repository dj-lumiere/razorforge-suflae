# ============================================================================
# Text Parsing (CStr -> primitive values)
# Native C functions that parse null-terminated UTF-8 strings
# Integer parsing is pure RazorForge (in each type's .rf file)
# ============================================================================

### Returns the result of `rf parse F16`.
### :param cstr: The `cstr` value.
### :returns: The resulting `F16` value.
external("C") routine rf_parse_F16(cstr: CStr) -> F16
### Returns the result of `rf parse F32`.
### :param cstr: The `cstr` value.
### :returns: The resulting `F32` value.
external("C") routine rf_parse_F32(cstr: CStr) -> F32
### Returns the result of `rf parse F64`.
### :param cstr: The `cstr` value.
### :returns: The resulting `F64` value.
external("C") routine rf_parse_F64(cstr: CStr) -> F64
### Returns the result of `rf parse F128`.
### :param cstr: The `cstr` value.
### :returns: The resulting `F128` value.
external("C") routine rf_parse_F128(cstr: CStr) -> F128

# ============================================================================
# Text Formatting (primitive values -> heap-allocated CStr pointer)
# Returns Address to heap-allocated null-terminated UTF-8 string
# Integer formatting is pure RazorForge (in each type's .rf file)
# ============================================================================

### Returns the result of `rf format F16`.
### :param value: The value to use.
### :returns: The resulting `Address` value.
external("C") routine rf_format_F16(value: F16) -> Address
### Returns the result of `rf format F32`.
### :param value: The value to use.
### :returns: The resulting `Address` value.
external("C") routine rf_format_F32(value: F32) -> Address
### Returns the result of `rf format F64`.
### :param value: The value to use.
### :returns: The resulting `Address` value.
external("C") routine rf_format_F64(value: F64) -> Address
### Returns the result of `rf format F128`.
### :param value: The value to use.
### :returns: The resulting `Address` value.
external("C") routine rf_format_F128(value: F128) -> Address

