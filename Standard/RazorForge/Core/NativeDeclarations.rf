### :param a_high: The `a_high` value.
### :param b_low: The `b_low` value.
### :param b_high: The `b_high` value.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_div(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> D128

