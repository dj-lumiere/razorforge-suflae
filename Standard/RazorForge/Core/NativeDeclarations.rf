external("C") routine rf_f128_cosh(value: F128) -> F128
external("C") routine rf_f128_tanh(value: F128) -> F128
external("C") routine rf_f128_asinh(value: F128) -> F128
external("C") routine rf_f128_acosh(value: F128) -> F128
external("C") routine rf_f128_atanh(value: F128) -> F128

