# Native C FFI routine declarations for all stdlib types
# These declare external C functions implemented in the RazorForge native runtime
# Companion to LLVMIntrinsics.rf which declares LLVM-level intrinsics
module Core

# ============================================================================
# Memory Management
# ============================================================================

external("C") routine rf_runtime_init()
dangerous external("C") routine rf_allocate_dynamic(size: U64) -> Address
dangerous external("C") routine rf_reallocate_dynamic(ptr: Address, size: U64) -> Address
dangerous external("C") routine rf_invalidate(ptr: Address)
dangerous external("C") routine rf_copy_bytes_at(dest: Address, src: Address, size: U64)
dangerous external("C") routine rf_set_bytes_at(dest: Address, value: U8, size: U64)

# ============================================================================
# Task Runtime
# ============================================================================

external("C") routine rf_task_create(kind: S32) -> Address
external("C") routine rf_task_destroy(task: Address)
external("C") routine rf_task_id(task: Address) -> U64
external("C") routine rf_task_kind_get(task: Address) -> S32
external("C") routine rf_task_status_get(task: Address) -> S32
external("C") routine rf_task_completion_kind_get(task: Address) -> S32
external("C") routine rf_task_result_payload(task: Address) -> Address
external("C") routine rf_task_error_payload(task: Address) -> Address
external("C") routine rf_task_wait(task: Address) -> S32
external("C") routine rf_task_wait_within(task: Address, timeout_seconds: S64, timeout_nanoseconds: U32) -> S32
external("C") routine rf_task_spawn_threaded(task: Address, entry: Address, userdata: Address) -> S32
external("C") routine rf_task_mark_ready(task: Address)
external("C") routine rf_task_mark_running(task: Address)
external("C") routine rf_task_mark_parked(task: Address)
external("C") routine rf_task_complete_value(task: Address, result_payload: Address)
external("C") routine rf_task_complete_error(task: Address, error_payload: Address)
external("C") routine rf_task_complete_cancelled(task: Address)
external("C") routine rf_task_complete_timeout(task: Address)
external("C") routine rf_task_request_cancel(task: Address)
external("C") routine rf_task_is_cancel_requested(task: Address) -> Bool
external("C") routine rf_task_mark_result_consumed(task: Address)
external("C") routine rf_task_is_result_consumed(task: Address) -> Bool
external("C") routine rf_task_attach_execution_backend(task: Address, backend: Address)
external("C") routine rf_task_execution_backend(task: Address) -> Address
external("C") routine rf_task_attach_wait_backend(task: Address, backend: Address)
external("C") routine rf_task_wait_backend(task: Address) -> Address
external("C") routine rf_task_add_prerequisite(task: Address)
external("C") routine rf_task_add_dependent(task: Address, dependent: Address)
external("C") routine rf_task_prerequisite_count(task: Address) -> U32
external("C") routine rf_task_prerequisites_remaining(task: Address) -> U32
external("C") routine rf_task_prerequisite_complete(task: Address, success: Bool) -> Bool
external("C") routine rf_waitfor_duration(duration_seconds: S64, duration_nanoseconds: U32)

# ============================================================================
# D32 (Decimal32) - Intel DFP Library
# All functions operate on U32 BID-encoded bits
# ============================================================================

# Construction from integer types
external("C") routine rf_d32_from_s32(value: S32) -> U32
external("C") routine rf_d32_from_s64(value: S64) -> U32
external("C") routine rf_d32_from_u32(value: U32) -> U32
external("C") routine rf_d32_from_u64(value: U64) -> U32

# Arithmetic (U32 bits in, U32 bits out)
external("C") routine rf_d32_add(a: U32, b: U32) -> U32
external("C") routine rf_d32_sub(a: U32, b: U32) -> U32
external("C") routine rf_d32_mul(a: U32, b: U32) -> U32
external("C") routine rf_d32_div(a: U32, b: U32) -> U32

# Comparison (returns S32: negative/zero/positive)
external("C") routine rf_d32_cmp(a: U32, b: U32) -> S32

# Math operations (U32 bits in, U32 bits out)
external("C") routine rf_d32_sqrt(value: U32) -> U32
external("C") routine rf_d32_abs(value: U32) -> U32
external("C") routine rf_d32_ceil(value: U32) -> U32
external("C") routine rf_d32_floor(value: U32) -> U32
external("C") routine rf_d32_round(value: U32) -> U32
external("C") routine rf_d32_trunc(value: U32) -> U32

# Conversion to other decimal sizes
external("C") routine rf_d32_to_d64(value: U32) -> U64
external("C") routine rf_d32_to_d128(value: U32) -> D128

# Conversion to binary floating point
external("C") routine rf_d32_to_f32(value: U32) -> F32
external("C") routine rf_d32_to_f64(value: U32) -> F64
external("C") routine rf_d32_to_f128(value: U32) -> F128

# Conversion from binary floating point to D32
external("C") routine rf_f32_to_d32(value: F32) -> U32
external("C") routine rf_f64_to_d32(value: F64) -> U32

# String conversion
external("C") routine rf_d32_to_string(bits: U32) -> Address
external("C") routine rf_d32_from_string(cstr: CStr) -> U32

# ============================================================================
# D64 (Decimal64) - Intel DFP Library
# All functions operate on U64 BID-encoded bits
# ============================================================================

# Construction from integer types
external("C") routine rf_d64_from_s32(value: S32) -> U64
external("C") routine rf_d64_from_s64(value: S64) -> U64
external("C") routine rf_d64_from_u32(value: U32) -> U64
external("C") routine rf_d64_from_u64(value: U64) -> U64

# Arithmetic (U64 bits in, U64 bits out)
external("C") routine rf_d64_add(a: U64, b: U64) -> U64
external("C") routine rf_d64_sub(a: U64, b: U64) -> U64
external("C") routine rf_d64_mul(a: U64, b: U64) -> U64
external("C") routine rf_d64_div(a: U64, b: U64) -> U64

# Comparison (returns S32: negative/zero/positive)
external("C") routine rf_d64_cmp(a: U64, b: U64) -> S32

# Math operations (U64 bits in, U64 bits out)
external("C") routine rf_d64_sqrt(value: U64) -> U64
external("C") routine rf_d64_abs(value: U64) -> U64
external("C") routine rf_d64_ceil(value: U64) -> U64
external("C") routine rf_d64_floor(value: U64) -> U64
external("C") routine rf_d64_round(value: U64) -> U64
external("C") routine rf_d64_trunc(value: U64) -> U64

# Conversion to other decimal sizes
external("C") routine rf_d64_to_d32(value: U64) -> U32
external("C") routine rf_d64_to_d128(value: U64) -> D128

# Conversion to binary floating point
external("C") routine rf_d64_to_f32(value: U64) -> F32
external("C") routine rf_d64_to_f64(value: U64) -> F64
external("C") routine rf_d64_to_f128(value: U64) -> F128

# Conversion from binary floating point to D64
external("C") routine rf_f32_to_d64(value: F32) -> U64
external("C") routine rf_f64_to_d64(value: F64) -> U64

# String conversion
external("C") routine rf_d64_to_string(bits: U64) -> Address
external("C") routine rf_d64_from_string(cstr: CStr) -> U64

# ============================================================================
# D128 (Decimal128) - Intel DFP Library
# D128 functions take (low: U64, high: U64) pairs and return D128
# ============================================================================

# Construction from integer types
external("C") routine rf_d128_from_s32(value: S32) -> D128
external("C") routine rf_d128_from_s64(value: S64) -> D128
external("C") routine rf_d128_from_u32(value: U32) -> D128
external("C") routine rf_d128_from_u64(value: U64) -> D128

# Arithmetic (split U64 pairs in, D128 out)
external("C") routine rf_d128_add(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> D128
external("C") routine rf_d128_sub(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> D128
external("C") routine rf_d128_mul(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> D128
external("C") routine rf_d128_div(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> D128

# Comparison (returns S32: negative/zero/positive)
external("C") routine rf_d128_cmp(a_low: U64, a_high: U64, b_low: U64, b_high: U64) -> S32

# Math operations (split U64 pair in, D128 out)
external("C") routine rf_d128_sqrt(low: U64, high: U64) -> D128
external("C") routine rf_d128_abs(low: U64, high: U64) -> D128
external("C") routine rf_d128_ceil(low: U64, high: U64) -> D128
external("C") routine rf_d128_floor(low: U64, high: U64) -> D128
external("C") routine rf_d128_round(low: U64, high: U64) -> D128
external("C") routine rf_d128_trunc(low: U64, high: U64) -> D128

# Trigonometric functions (via F128 conversion + LibBF)
external("C") routine rf_d128_sin(low: U64, high: U64) -> D128
external("C") routine rf_d128_cos(low: U64, high: U64) -> D128
external("C") routine rf_d128_tan(low: U64, high: U64) -> D128
external("C") routine rf_d128_asin(low: U64, high: U64) -> D128
external("C") routine rf_d128_acos(low: U64, high: U64) -> D128
external("C") routine rf_d128_atan(low: U64, high: U64) -> D128
external("C") routine rf_d128_atan2(y_low: U64, y_high: U64, x_low: U64, x_high: U64) -> D128

# Hyperbolic functions
external("C") routine rf_d128_sinh(low: U64, high: U64) -> D128
external("C") routine rf_d128_cosh(low: U64, high: U64) -> D128
external("C") routine rf_d128_tanh(low: U64, high: U64) -> D128

# Exponential and logarithmic functions
external("C") routine rf_d128_exp(low: U64, high: U64) -> D128
external("C") routine rf_d128_exp2(low: U64, high: U64) -> D128
external("C") routine rf_d128_log(low: U64, high: U64) -> D128
external("C") routine rf_d128_log2(low: U64, high: U64) -> D128
external("C") routine rf_d128_log10(low: U64, high: U64) -> D128

# Power functions
external("C") routine rf_d128_pow(base_low: U64, base_high: U64, exp_low: U64, exp_high: U64) -> D128
external("C") routine rf_d128_cbrt(low: U64, high: U64) -> D128
external("C") routine rf_d128_hypot(x_low: U64, x_high: U64, y_low: U64, y_high: U64) -> D128

# Conversion to other decimal sizes
external("C") routine rf_d128_to_d32(low: U64, high: U64) -> U32
external("C") routine rf_d128_to_d64(low: U64, high: U64) -> U64

# Conversion to binary floating point
external("C") routine rf_d128_to_f32(low: U64, high: U64) -> F32
external("C") routine rf_d128_to_f64(low: U64, high: U64) -> F64
external("C") routine rf_d128_to_f128(low: U64, high: U64) -> F128

# Conversion from binary floating point to D128
external("C") routine rf_f32_to_d128(value: F32) -> D128
external("C") routine rf_f64_to_d128(value: F64) -> D128

# String conversion
external("C") routine rf_d128_to_string(low: U64, high: U64) -> Address
external("C") routine rf_d128_from_string(cstr: CStr) -> D128

# ============================================================================
# Decimal-to-integer conversion (non-rf_ prefixed C functions)
# Used by S32.rf and S64.rf for D32/D64/D128 -> integer conversion
# ============================================================================

external("C") routine d32_to_s32(bits: U32) -> S32
external("C") routine d64_to_s32(bits: U64) -> S32
external("C") routine d128_to_s32(low: U64, high: U64) -> S32

external("C") routine d32_to_s64(bits: U32) -> S64
external("C") routine d64_to_s64(bits: U64) -> S64
external("C") routine d128_to_s64(low: U64, high: U64) -> S64

