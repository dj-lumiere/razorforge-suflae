### :param low: The `low` value.
### :param high: The `high` value.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_floor(low: U64, high: U64) -> D128
### Returns the result of `rf d128 round`.
### :param low: The `low` value.
### :param high: The `high` value.
### :returns: The resulting `D128` value.
external("C") routine rf_d128_round(low: U64, high: U64) -> D128
### Returns the result of `rf d128 trunc`.
