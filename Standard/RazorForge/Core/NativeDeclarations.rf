# Native C FFI routine declarations for all stdlib types
# These declare external C functions implemented in the RazorForge native runtime
# Companion to LLVMIntrinsics.rf which declares LLVM-level intrinsics
module Core

# ============================================================================
# Memory Management
# ============================================================================

### Executes `rf runtime init`.
external("C") routine rf_runtime_init()
### Returns the result of `rf allocate dynamic`.
### :param size: The size value to use.
### :returns: The resulting `Address` value.
dangerous external("C") routine rf_allocate_dynamic(size: U64) -> Address
### Returns the result of `rf allocate dynamic`.
### :param size: The size value to use.
### :returns: The resulting `Address` value.
dangerous routine rf_allocate_dynamic(size: ByteSize) -> Address
  return rf_allocate_dynamic(size: size.byte_size())
### Returns uninitialized dynamic memory — caller must write before reading.
### :param size: The byte count to allocate.
### :returns: The resulting `Address` value.
dangerous external("C") routine rf_allocate_dynamic_uninit(size: U64) -> Address
### Returns uninitialized dynamic memory — caller must write before reading.
### :param size: The byte count to allocate.
### :returns: The resulting `Address` value.
dangerous routine rf_allocate_dynamic_uninit(size: ByteSize) -> Address
  return rf_allocate_dynamic_uninit(size: size.byte_size())
### Returns the result of `rf reallocate dynamic`.
### :param ptr: The pointer value to use.
### :param size: The size value to use.
### :returns: The resulting `Address` value.
dangerous external("C") routine rf_reallocate_dynamic(ptr: Address, size: U64) -> Address
### Returns the result of `rf reallocate dynamic`.
### :param ptr: The pointer value to use.
### :param size: The size value to use.
### :returns: The resulting `Address` value.
dangerous routine rf_reallocate_dynamic(ptr: Address, size: ByteSize) -> Address
  return rf_reallocate_dynamic(ptr: ptr, size: size.byte_size())
### Performs `rf invalidate` on this value.
### :param ptr: The pointer value to use.
dangerous external("C") routine rf_invalidate(ptr: Address)
### Performs `rf copy bytes at` on this value.
### :param dest: The destination location.
### :param src: The source location.
### :param size: The size value to use.
dangerous external("C") routine rf_copy_bytes_at(dest: Address, src: Address, size: U64)
### Performs `rf copy bytes at` on this value.
### :param dest: The destination location.
### :param src: The source location.
### :param size: The size value to use.
dangerous routine rf_copy_bytes_at(dest: Address, src: Address, size: ByteSize)
  rf_copy_bytes_at(dest: dest, src: src, size: size.byte_size())
  return
### Performs `rf set bytes at` on this value.
### :param dest: The destination location.
### :param value: The value to use.
### :param size: The size value to use.
dangerous external("C") routine rf_set_bytes_at(dest: Address, value: U8, size: U64)
### Performs `rf set bytes at` on this value.
### :param dest: The destination location.
### :param value: The value to use.
### :param size: The size value to use.
dangerous routine rf_set_bytes_at(dest: Address, value: U8, size: ByteSize)
  rf_set_bytes_at(dest: dest, value: value, size: size.byte_size())
  return

# ============================================================================
# Task Runtime
# ============================================================================

### Returns the result of `rf task create`.
### :param kind: The task kind value.
### :returns: The resulting `Address` value.
external("C") routine rf_task_create(kind: S32) -> Address
### Performs `rf task destroy` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_destroy(task: Address)
### Returns the result of `rf task id`.
### :param task: The task handle to use.
### :returns: The resulting `U64` value.
external("C") routine rf_task_id(task: Address) -> U64
### Returns the result of `rf task kind get`.
### :param task: The task handle to use.
### :returns: The resulting `S32` value.
external("C") routine rf_task_kind_get(task: Address) -> S32
### Returns the result of `rf task status get`.
### :param task: The task handle to use.
### :returns: The resulting `S32` value.
external("C") routine rf_task_status_get(task: Address) -> S32
### Returns the result of `rf task completion kind get`.
### :param task: The task handle to use.
### :returns: The resulting `S32` value.
external("C") routine rf_task_completion_kind_get(task: Address) -> S32
### Returns the result of `rf task result payload`.
### :param task: The task handle to use.
### :returns: The resulting `Address` value.
external("C") routine rf_task_result_payload(task: Address) -> Address
### Returns the result of `rf task error payload`.
### :param task: The task handle to use.
### :returns: The resulting `Address` value.
external("C") routine rf_task_error_payload(task: Address) -> Address
### Returns the result of `rf task wait`.
### :param task: The task handle to use.
### :returns: The resulting `S32` value.
external("C") routine rf_task_wait(task: Address) -> S32
### Returns the result of `rf task wait within`.
### :param task: The task handle to use.
### :param timeout_seconds: The timeout seconds component.
### :param timeout_nanoseconds: The timeout nanoseconds component.
### :returns: The resulting `S32` value.
external("C") routine rf_task_wait_within(task: Address, timeout_seconds: S64, timeout_nanoseconds: U32) -> S32
### Returns the result of `rf task spawn threaded`.
### :param task: The task handle to use.
### :param entry: The entry routine pointer.
### :param userdata: The user data pointer.
### :returns: The resulting `S32` value.
external("C") routine rf_task_spawn_threaded(task: Address, entry: Address, userdata: Address) -> S32
### Performs `rf task mark ready` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_mark_ready(task: Address)
### Performs `rf task mark running` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_mark_running(task: Address)
### Performs `rf task mark parked` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_mark_parked(task: Address)
### Performs `rf task complete value` on this value.
### :param task: The task handle to use.
### :param result_payload: The `result_payload` value.
external("C") routine rf_task_complete_value(task: Address, result_payload: Address)
### Performs `rf task complete error` on this value.
### :param task: The task handle to use.
### :param error_payload: The `error_payload` value.
external("C") routine rf_task_complete_error(task: Address, error_payload: Address)
### Performs `rf task complete cancelled` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_complete_cancelled(task: Address)
### Performs `rf task complete timeout` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_complete_timeout(task: Address)
### Performs `rf task request cancel` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_request_cancel(task: Address)
### Returns the result of `rf task is cancel requested`.
### :param task: The task handle to use.
### :returns: The resulting `Bool` value.
external("C") routine rf_task_is_cancel_requested(task: Address) -> Bool
### Performs `rf task mark result consumed` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_mark_result_consumed(task: Address)
### Returns the result of `rf task is result consumed`.
### :param task: The task handle to use.
### :returns: The resulting `Bool` value.
external("C") routine rf_task_is_result_consumed(task: Address) -> Bool
### Performs `rf task attach execution backend` on this value.
### :param task: The task handle to use.
### :param backend: The backend to attach.
external("C") routine rf_task_attach_execution_backend(task: Address, backend: Address)
### Returns the result of `rf task execution backend`.
### :param task: The task handle to use.
### :returns: The resulting `Address` value.
external("C") routine rf_task_execution_backend(task: Address) -> Address
### Performs `rf task attach wait backend` on this value.
### :param task: The task handle to use.
### :param backend: The backend to attach.
external("C") routine rf_task_attach_wait_backend(task: Address, backend: Address)
### Returns the result of `rf task wait backend`.
### :param task: The task handle to use.
### :returns: The resulting `Address` value.
external("C") routine rf_task_wait_backend(task: Address) -> Address
### Performs `rf task add prerequisite` on this value.
### :param task: The task handle to use.
external("C") routine rf_task_add_prerequisite(task: Address)
### Performs `rf task add dependent` on this value.
### :param task: The task handle to use.
### :param dependent: The `dependent` value.
external("C") routine rf_task_add_dependent(task: Address, dependent: Address)
### Returns the result of `rf task prerequisite count`.
### :param task: The task handle to use.
### :returns: The resulting `U32` value.
external("C") routine rf_task_prerequisite_count(task: Address) -> U32
### Returns the result of `rf task prerequisites remaining`.
### :param task: The task handle to use.
### :returns: The resulting `U32` value.
external("C") routine rf_task_prerequisites_remaining(task: Address) -> U32
### Returns the result of `rf task prerequisite complete`.
### :param task: The task handle to use.
### :param success: The `success` value.
### :returns: The resulting `Bool` value.
external("C") routine rf_task_prerequisite_complete(task: Address, success: Bool) -> Bool
### Performs `rf waitfor duration` on this value.
### :param duration_seconds: The duration seconds component.
### :param duration_nanoseconds: The duration nanoseconds component.
external("C") routine rf_waitfor_duration(duration_seconds: S64, duration_nanoseconds: U32)

# ============================================================================
# D32 (Decimal32) - Intel DFP Library
# All functions operate on U32 BID-encoded bits
# ============================================================================

### Returns the result of `rf d32 from s32`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_from_s32(value: S32) -> U32
### Returns the result of `rf d32 from s64`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_from_s64(value: S64) -> U32
### Returns the result of `rf d32 from u32`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_from_u32(value: U32) -> U32
### Returns the result of `rf d32 from u64`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_from_u64(value: U64) -> U32

### Returns the result of `rf d32 add`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_add(a: U32, b: U32) -> U32
### Returns the result of `rf d32 sub`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_sub(a: U32, b: U32) -> U32
### Returns the result of `rf d32 mul`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_mul(a: U32, b: U32) -> U32
### Returns the result of `rf d32 div`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_div(a: U32, b: U32) -> U32

### Returns the result of `rf d32 cmp`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `S32` value.
external("C") routine rf_d32_cmp(a: U32, b: U32) -> S32
external("C") routine rf_d32_isfinite(bits: U32) -> S32

### Returns the result of `rf d32 sqrt`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_sqrt(value: U32) -> U32
### Returns the result of `rf d32 abs`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_abs(value: U32) -> U32
### Returns the result of `rf d32 ceil`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_ceil(value: U32) -> U32
### Returns the result of `rf d32 floor`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_floor(value: U32) -> U32
### Returns the result of `rf d32 round`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_round(value: U32) -> U32
### Returns the result of `rf d32 trunc`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_trunc(value: U32) -> U32

### Returns the result of `rf d32 to d64`.
### :param value: The value to use.
### :returns: The resulting `U64` value.
external("C") routine rf_d32_to_d64(value: U32) -> U64
### Returns the result of `rf d32 to d128`.
### :param value: The value to use.
### :returns: The resulting `D128` value.
external("C") routine rf_d32_to_d128(value: U32) -> D128

### Returns the result of `rf d32 to f32`.
### :param value: The value to use.
### :returns: The resulting `F32` value.
external("C") routine rf_d32_to_f32(value: U32) -> F32
### Returns the result of `rf d32 to f64`.
### :param value: The value to use.
### :returns: The resulting `F64` value.
external("C") routine rf_d32_to_f64(value: U32) -> F64
### Returns the result of `rf d32 to f128`.
### :param value: The value to use.
### :returns: The resulting `F128` value.
external("C") routine rf_d32_to_f128(value: U32) -> F128

### Returns the result of `rf f32 to d32`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_f32_to_d32(value: F32) -> U32
### Returns the result of `rf f64 to d32`.
### :param value: The value to use.
### :returns: The resulting `U32` value.
external("C") routine rf_f64_to_d32(value: F64) -> U32

### Returns the result of `rf d32 to string`.
### :param bits: The encoded bit pattern.
### :returns: The resulting `Address` value.
external("C") routine rf_d32_to_string(bits: U32) -> Address
### Returns the result of `rf d32 from string`.
### :param cstr: The `cstr` value.
### :returns: The resulting `U32` value.
external("C") routine rf_d32_from_string(cstr: CStr) -> U32

