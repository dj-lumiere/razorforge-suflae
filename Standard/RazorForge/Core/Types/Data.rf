# Data - Universal type-erased box
# Holds any storable value with runtime type information
# Cannot box: Result, Lookup, variants, access tokens
module Core

### Defines the record `Data`.
record Data
  ### The type identifier of the boxed value.
  secret type_id: U64
  ### The address of the heap-allocated boxed value.
  secret data_address: Address
  ### The size in bytes of the boxed value.
  secret data_size: ByteSize
