external("llvm") routine signed_le[T](a: T, b: T) -> Bool
### Returns the result of `signed_gt`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp sgt {T} {a}, {b}")
external("llvm") routine signed_gt[T](a: T, b: T) -> Bool
### Returns the result of `signed_ge`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp sge {T} {a}, {b}")
external("llvm") routine signed_ge[T](a: T, b: T) -> Bool
### Returns the result of `unsigned_lt`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp ult {T} {a}, {b}")
