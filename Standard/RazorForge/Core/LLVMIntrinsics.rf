### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.cos.{T}({T} {value})")
external("llvm") routine cos[T](value: T) -> T
### Returns the result of `exp`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.exp.{T}({T} {value})")
external("llvm") routine exp[T](value: T) -> T
### Returns the result of `log`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.log.{T}({T} {value})")
external("llvm") routine log[T](value: T) -> T
### Returns the result of `log10`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.log10.{T}({T} {value})")
external("llvm") routine log10[T](value: T) -> T
### Returns the result of `pow`.
