# ============================================================================
# Saturating Arithmetic (@llvm.s/u{add,sub}.sat)
# ============================================================================

### Returns the result of `sadd sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.sadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine sadd_sat[T](a: T, b: T) -> T
### Returns the result of `uadd sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.uadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine uadd_sat[T](a: T, b: T) -> T
### Returns the result of `ssub sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.ssub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine ssub_sat[T](a: T, b: T) -> T
### Returns the result of `usub sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.usub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine usub_sat[T](a: T, b: T) -> T

# ============================================================================
# Overflow Detection (@llvm.s/u{add,sub,mul}.with.overflow)
# ============================================================================

### Returns the result of `sadd with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.sadd.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine sadd_with_overflow[T](a: T, b: T) -> (T, Bool)
### Returns the result of `uadd with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.uadd.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine uadd_with_overflow[T](a: T, b: T) -> (T, Bool)
### Returns the result of `ssub with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.ssub.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine ssub_with_overflow[T](a: T, b: T) -> (T, Bool)
### Returns the result of `usub with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.usub.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine usub_with_overflow[T](a: T, b: T) -> (T, Bool)
### Returns the result of `smul with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.smul.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine smul_with_overflow[T](a: T, b: T) -> (T, Bool)
### Returns the result of `umul with overflow`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.umul.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine umul_with_overflow[T](a: T, b: T) -> (T, Bool)

