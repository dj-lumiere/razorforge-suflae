@llvm_ir("{result} = call {T} @llvm.copysign.{T}({T} {value}, {T} {sign})")
external("llvm") routine copysign[T](value: T, sign: T) -> T

# ============================================================================
# Atomic Operations
# ============================================================================

@llvm_ir("{result} = load atomic {T}, ptr {ptr} seq_cst, align {sizeof T}")
external("llvm") routine atomic_load[T](ptr: Snatched[T]) -> T
@llvm_ir("store atomic {T} {value}, ptr {ptr} seq_cst, align {sizeof T}")
external("llvm") routine atomic_store[T](ptr: Snatched[T], value: T)
@llvm_ir("{result} = atomicrmw add ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_add[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = atomicrmw sub ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_sub[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = atomicrmw and ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_and[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = atomicrmw or ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_or[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = atomicrmw xor ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_xor[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = atomicrmw xchg ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_exchange[T](ptr: Snatched[T], value: T) -> T
@llvm_ir("{result} = cmpxchg ptr {ptr}, {T} {expected}, {T} {desired} seq_cst seq_cst")
external("llvm") routine atomic_compare_and_exchange[T](ptr: Snatched[T], expected: T, desired: T) -> (T, Bool)
