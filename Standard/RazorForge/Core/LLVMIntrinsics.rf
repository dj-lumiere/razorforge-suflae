# ============================================================================
# Atomic Operations
# ============================================================================

### Returns the result of `atomic load`.
### :param ptr: The pointer value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = load atomic {T}, ptr {ptr} seq_cst, align {sizeof T}")
external("llvm") routine atomic_load[T](ptr: Hijacked[T]) -> T
### Performs `atomic store` on this value.
### :param ptr: The pointer value to use.
### :param value: The value to use.
@llvm_ir("store atomic {T} {value}, ptr {ptr} seq_cst, align {sizeof T}")
external("llvm") routine atomic_store[T](ptr: Hijacked[T], value: T)
### Returns the result of `atomic add`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw add ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_add[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic sub`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw sub ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_sub[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic and`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw and ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_and[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic or`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw or ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_or[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic xor`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw xor ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_xor[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic exchange`.
### :param ptr: The pointer value to use.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = atomicrmw xchg ptr {ptr}, {T} {value} seq_cst")
external("llvm") routine atomic_exchange[T](ptr: Hijacked[T], value: T) -> T
### Returns the result of `atomic compare and exchange`.
### :param ptr: The pointer value to use.
### :param expected: The value expected to be present.
### :param desired: The value to store on success.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = cmpxchg ptr {ptr}, {T} {expected}, {T} {desired} seq_cst seq_cst")
external("llvm") routine atomic_compare_and_exchange[T](ptr: Hijacked[T], expected: T, desired: T) -> (T, Bool)

# ============================================================================
# Array element access (alloca + GEP pattern for [N x T] record types)
# ============================================================================

### Returns the result of `byte at`.
### :param array: The `array` value.
### :param index: The zero-based position to use.
### :returns: The resulting `U8` value.
@llvm_ir("{result} = alloca {Array}\nstore {Array} {array}, ptr {prev}\n{result} = getelementptr {Array}, ptr {prev}, i32 0, i64 {index}\n{result} = load i8, ptr {prev}")
external("llvm") routine byte_at[Array](array: Array, index: U64) -> U8

### Sets the byte at component.
### :param array: The `array` value.
### :param index: The zero-based position to use.
### :param value: The value to use.
### :returns: The resulting `Array` value.
@llvm_ir("{result} = alloca {Array}\nstore {Array} {array}, ptr {prev}\n{result} = getelementptr {Array}, ptr {prev}, i32 0, i64 {index}\nstore i8 {value}, ptr {prev}\n{result} = load {Array}, ptr {first}")
external("llvm") routine set_byte_at[Array](array: Array, index: U64, value: U8) -> Array

### Returns the result of `element at`.
### :param array: The `array` value.
### :param index: The zero-based position to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = alloca {Array}\nstore {Array} {array}, ptr {prev}\n{result} = getelementptr {Array}, ptr {prev}, i32 0, i64 {index}\n{result} = load {T}, ptr {prev}")
external("llvm") routine element_at[Array, T](array: Array, index: U64) -> T

### Sets the element at component.
### :param array: The `array` value.
### :param index: The zero-based position to use.
### :param value: The value to use.
### :returns: The resulting `Array` value.
@llvm_ir("{result} = alloca {Array}\nstore {Array} {array}, ptr {prev}\n{result} = getelementptr {Array}, ptr {prev}, i32 0, i64 {index}\nstore {T} {value}, ptr {prev}\n{result} = load {Array}, ptr {first}")
external("llvm") routine set_element_at[Array, T](array: Array, index: U64, value: T) -> Array
