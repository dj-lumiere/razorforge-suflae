dangerous external("llvm") routine mul_nsw[T](a: T, b: T) -> T
### Returns the result of `mul nuw` (no unsigned wrap — UB on unsigned overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = mul nuw {T} {a}, {b}")
dangerous external("llvm") routine mul_nuw[T](a: T, b: T) -> T
### Returns the result of `sdiv`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = sdiv {T} {a}, {b}")
external("llvm") routine sdiv[T](a: T, b: T) -> T
### Returns the result of `udiv`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = udiv {T} {a}, {b}")
external("llvm") routine udiv[T](a: T, b: T) -> T
### Returns the result of `srem`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = srem {T} {a}, {b}")
