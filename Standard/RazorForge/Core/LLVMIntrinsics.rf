# ============================================================================
# Saturating Arithmetic (@llvm.s/u{add,sub}.sat)
# ============================================================================

@llvm_ir("{result} = call {T} @llvm.sadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine sadd_sat[T](a: T, b: T) -> T
@llvm_ir("{result} = call {T} @llvm.uadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine uadd_sat[T](a: T, b: T) -> T
@llvm_ir("{result} = call {T} @llvm.ssub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine ssub_sat[T](a: T, b: T) -> T
@llvm_ir("{result} = call {T} @llvm.usub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine usub_sat[T](a: T, b: T) -> T

# ============================================================================
# Overflow Detection (@llvm.s/u{add,sub,mul}.with.overflow)
# ============================================================================

@llvm_ir("{result} = call { {T}, i1 } @llvm.sadd.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine sadd_with_overflow[T](a: T, b: T) -> (T, Bool)
@llvm_ir("{result} = call { {T}, i1 } @llvm.uadd.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine uadd_with_overflow[T](a: T, b: T) -> (T, Bool)
@llvm_ir("{result} = call { {T}, i1 } @llvm.ssub.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine ssub_with_overflow[T](a: T, b: T) -> (T, Bool)
@llvm_ir("{result} = call { {T}, i1 } @llvm.usub.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine usub_with_overflow[T](a: T, b: T) -> (T, Bool)
@llvm_ir("{result} = call { {T}, i1 } @llvm.smul.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine smul_with_overflow[T](a: T, b: T) -> (T, Bool)
@llvm_ir("{result} = call { {T}, i1 } @llvm.umul.with.overflow.{T}({T} {a}, {T} {b})\n{result} = extractvalue { {T}, i1 } {prev}, 0")
external("llvm") routine umul_with_overflow[T](a: T, b: T) -> (T, Bool)

# ============================================================================
# Integer Bit Manipulation (@llvm.ctpop, @llvm.ctlz, etc.)
# ============================================================================

@llvm_ir("{result} = call {T} @llvm.ctpop.{T}({T} {value})")
external("llvm") routine ctpop[T](value: T) -> T
@llvm_ir("{result} = call {T} @llvm.ctlz.{T}({T} {value}, i1 false)")
external("llvm") routine ctlz[T](value: T) -> T
@llvm_ir("{result} = call {T} @llvm.cttz.{T}({T} {value}, i1 false)")
external("llvm") routine cttz[T](value: T) -> T
@llvm_ir("{result} = call {T} @llvm.bitreverse.{T}({T} {value})")
external("llvm") routine bitreverse[T](value: T) -> T
@llvm_ir("{result} = call {T} @llvm.bswap.{T}({T} {value})")
external("llvm") routine bswap[T](value: T) -> T
@llvm_ir("{result} = call {T} @llvm.abs.{T}({T} {value}, i1 false)")
external("llvm") routine abs[T](value: T) -> T

