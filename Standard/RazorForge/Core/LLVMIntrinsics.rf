### Returns the result of `unsigned_le`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp ule {T} {a}, {b}")
external("llvm") routine unsigned_le[T](a: T, b: T) -> Bool
### Returns the result of `unsigned_gt`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp ugt {T} {a}, {b}")
external("llvm") routine unsigned_gt[T](a: T, b: T) -> Bool
### Returns the result of `unsigned_ge`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `Bool` value.
@llvm_ir("{result} = icmp uge {T} {a}, {b}")
external("llvm") routine unsigned_ge[T](a: T, b: T) -> Bool

