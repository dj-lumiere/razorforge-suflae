### Returns the result of `float_add`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fadd {T} {a}, {b}")
external("llvm") routine float_add[T](a: T, b: T) -> T
### Returns the result of `float_sub`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fsub {T} {a}, {b}")
external("llvm") routine float_sub[T](a: T, b: T) -> T
### Returns the result of `float_mul`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fmul {T} {a}, {b}")
external("llvm") routine float_mul[T](a: T, b: T) -> T
### Returns the result of `float_div`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fdiv {T} {a}, {b}")
external("llvm") routine float_div[T](a: T, b: T) -> T
### Returns the result of `float_div_fast` (no NaN/inf checks — UB if result is non-finite).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fdiv fast {T} {a}, {b}")
dangerous external("llvm") routine float_div_fast[T](a: T, b: T) -> T
### Returns the result of `float_rem`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = frem {T} {a}, {b}")
external("llvm") routine float_rem[T](a: T, b: T) -> T
### Returns the result of `float_neg`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = fneg {T} {value}")
external("llvm") routine float_neg[T](value: T) -> T

# ============================================================================
# Bitwise Instructions (and/or are RF keywords, prefixed with bit_)
# ============================================================================

### Returns the result of `bit and`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = and {T} {a}, {b}")
external("llvm") routine bit_and[T](a: T, b: T) -> T
### Returns the result of `bit or`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = or {T} {a}, {b}")
external("llvm") routine bit_or[T](a: T, b: T) -> T
### Returns the result of `bit_xor`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = xor {T} {a}, {b}")
external("llvm") routine bit_xor[T](a: T, b: T) -> T

# ============================================================================
# Shift Instructions
# ============================================================================

### Returns the result of `shift_left`.
### :param value: The value to use.
### :param bits: The encoded bit pattern.
### :returns: The resulting `T` value.
@llvm_ir("{result} = shl {T} {value}, {bits}")
external("llvm") routine shift_left[T](value: T, bits: T) -> T
### Returns the result of `shift_right_signed`.
### :param value: The value to use.
### :param bits: The encoded bit pattern.
### :returns: The resulting `T` value.
@llvm_ir("{result} = ashr {T} {value}, {bits}")
external("llvm") routine shift_right_signed[T](value: T, bits: T) -> T
### Returns the result of `shift_right_unsigned`.
### :param value: The value to use.
### :param bits: The encoded bit pattern.
### :returns: The resulting `T` value.
@llvm_ir("{result} = lshr {T} {value}, {bits}")
external("llvm") routine shift_right_unsigned[T](value: T, bits: T) -> T

