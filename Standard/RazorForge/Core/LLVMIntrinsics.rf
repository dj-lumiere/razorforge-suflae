# LLVM IR instruction and intrinsic function declarations.
# Every routine here maps 1:1 to a real LLVM instruction or @llvm.* intrinsic.
#
# @llvm_ir("template") is a mold string with {holes} for substitution:
#   {result} → next SSA temp    {paramName} → emitted arg by parameter name
#   {T}      → first type arg   {From}, {To}  → named type args
#   {prev}   → previous line's {result}   {sizeof T} → byte size
module Core

# ============================================================================
# Memory Operations
# ============================================================================

### Returns the result of `load`.
### :param address: The `address` value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = load {T}, ptr {address}")
external("llvm") routine load[T](address: Hijacked[T]) -> T
### Performs `store` on this value.
### :param address: The `address` value.
### :param value: The value to use.
@llvm_ir("store {T} {value}, ptr {address}")
dangerous external("llvm") routine store[T](address: Hijacked[T], value: T)

# ============================================================================
# Type Conversions
# ============================================================================

### Returns the result of `sign_extend`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = sext {From} {value} to {To}")
external("llvm") routine sign_extend[From, To](value: From) -> To
### Returns the result of `zero_extend`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = zext {From} {value} to {To}")
external("llvm") routine zero_extend[From, To](value: From) -> To
### Returns the result of `int_truncate`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = trunc {From} {value} to {To}")
external("llvm") routine int_truncate[From, To](value: From) -> To
### Returns the result of `reinterpret_bits`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = bitcast {From} {value} to {To}")
external("llvm") routine reinterpret_bits[From, To](value: From) -> To
### Returns the result of `pointer_to_int`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = ptrtoint ptr {value} to {To}")
external("llvm") routine pointer_to_int[From, To](value: Hijacked[From]) -> To
### Returns the result of `int_to_pointer`.
### :param value: The value to use.
### :returns: The resulting `Hijacked[To]` value.
@llvm_ir("{result} = inttoptr {From} {value} to ptr")
external("llvm") routine int_to_pointer[From, To](value: From) -> Hijacked[To]
### Returns the entity reference stored in a Hijacked pointer, without dereferencing.
### Use only when T is an entity type and the Hijacked holds the entity pointer directly.
### :param value: The raw pointer value.
### :returns: The resulting `T` entity reference.
@llvm_ir("{result} = getelementptr i8, ptr {value}, i64 0")
dangerous external("llvm") routine entity_from_hijacked[T](value: Hijacked[T]) -> T
### Steps a pointer forward by {count} elements of type {T} (element-sized stride).
### :param ptr: The base pointer.
### :param count: Number of elements to advance (may be negative to step backward).
### :returns: The resulting `Hijacked[T]` value.
@llvm_ir("{result} = getelementptr {T}, ptr {ptr}, i64 {count}")
dangerous external("llvm") routine element_pointer[T](ptr: Hijacked[T], count: S64) -> Hijacked[T]
### Returns the result of `signed_to_float`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = sitofp {From} {value} to {To}")
external("llvm") routine signed_to_float[From, To](value: From) -> To
### Returns the result of `unsigned_to_float`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = uitofp {From} {value} to {To}")
external("llvm") routine unsigned_to_float[From, To](value: From) -> To
### Returns the result of `float_to_signed`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = fptosi {From} {value} to {To}")
external("llvm") routine float_to_signed[From, To](value: From) -> To
### Returns the result of `float_to_unsigned`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = fptoui {From} {value} to {To}")
external("llvm") routine float_to_unsigned[From, To](value: From) -> To
### Returns the result of `float_extend`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = fpext {From} {value} to {To}")
external("llvm") routine float_extend[From, To](value: From) -> To
### Returns the result of `float_narrow`.
### :param value: The value to use.
### :returns: The resulting `To` value.
@llvm_ir("{result} = fptrunc {From} {value} to {To}")
external("llvm") routine float_narrow[From, To](value: From) -> To

# ============================================================================
# Integer Arithmetic Instructions
# ============================================================================

### Returns the result of `add`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = add {T} {a}, {b}")
external("llvm") routine add[T](a: T, b: T) -> T
### Returns the result of `signed_add_exact` (no signed wrap — UB on signed overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = add nsw {T} {a}, {b}")
dangerous external("llvm") routine signed_add_exact[T](a: T, b: T) -> T
### Returns the result of `unsigned_add_exact` (no unsigned wrap — UB on unsigned overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = add nuw {T} {a}, {b}")
dangerous external("llvm") routine unsigned_add_exact[T](a: T, b: T) -> T
### Returns the result of `sub`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = sub {T} {a}, {b}")
external("llvm") routine sub[T](a: T, b: T) -> T
### Returns the result of `signed_sub_exact` (no signed wrap — UB on signed overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = sub nsw {T} {a}, {b}")
dangerous external("llvm") routine signed_sub_exact[T](a: T, b: T) -> T
### Returns the result of `unsigned_sub_exact` (no unsigned wrap — UB on unsigned overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = sub nuw {T} {a}, {b}")
dangerous external("llvm") routine unsigned_sub_exact[T](a: T, b: T) -> T
### Returns the result of `mul`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = mul {T} {a}, {b}")
external("llvm") routine mul[T](a: T, b: T) -> T
### Returns the result of `signed_mul_exact` (no signed wrap — UB on signed overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = mul nsw {T} {a}, {b}")
dangerous external("llvm") routine signed_mul_exact[T](a: T, b: T) -> T
### Returns the result of `unsigned_mul_exact` (no unsigned wrap — UB on unsigned overflow).
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = mul nuw {T} {a}, {b}")
dangerous external("llvm") routine unsigned_mul_exact[T](a: T, b: T) -> T
### Returns the result of `signed_div`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = sdiv {T} {a}, {b}")
external("llvm") routine signed_div[T](a: T, b: T) -> T
### Returns the result of `unsigned_div`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = udiv {T} {a}, {b}")
external("llvm") routine unsigned_div[T](a: T, b: T) -> T
### Returns the result of `signed_rem`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = srem {T} {a}, {b}")
external("llvm") routine signed_rem[T](a: T, b: T) -> T
### Returns the result of `unsigned_rem`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = urem {T} {a}, {b}")
external("llvm") routine unsigned_rem[T](a: T, b: T) -> T

