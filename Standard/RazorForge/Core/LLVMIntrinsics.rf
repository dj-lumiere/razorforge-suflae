# LLVM IR instruction and intrinsic function declarations.
# Every routine here maps 1:1 to a real LLVM instruction or @llvm.* intrinsic.
#
# @llvm_ir("template") is a mold string with {holes} for substitution:
#   {result} → next SSA temp    {paramName} → emitted arg by parameter name
#   {T}      → first type arg   {From}, {To}  → named type args
#   {prev}   → previous line's {result}   {sizeof T} → byte size
module Core

# ============================================================================
# Memory Operations
# ============================================================================

@llvm_ir("{result} = load {T}, ptr {address}")
external("llvm") routine load[T](address: Snatched[T]) -> T
@llvm_ir("store {T} {value}, ptr {address}")
dangerous external("llvm") routine store[T](address: Snatched[T], value: T)
@llvm_ir("store volatile {T} {value}, ptr {address}")
dangerous external("llvm") routine store_volatile[T](address: Snatched[T], value: T)

# ============================================================================
# Type Conversions
# ============================================================================

@llvm_ir("{result} = sext {From} {value} to {To}")
external("llvm") routine sext[From, To](value: From) -> To
@llvm_ir("{result} = zext {From} {value} to {To}")
external("llvm") routine zext[From, To](value: From) -> To
@llvm_ir("{result} = trunc {From} {value} to {To}")
external("llvm") routine trunc[From, To](value: From) -> To
@llvm_ir("{result} = bitcast {From} {value} to {To}")
external("llvm") routine bitcast[From, To](value: From) -> To
@llvm_ir("{result} = sitofp {From} {value} to {To}")
external("llvm") routine sitofp[From, To](value: From) -> To
@llvm_ir("{result} = uitofp {From} {value} to {To}")
external("llvm") routine uitofp[From, To](value: From) -> To
@llvm_ir("{result} = fptosi {From} {value} to {To}")
external("llvm") routine fptosi[From, To](value: From) -> To
@llvm_ir("{result} = fptoui {From} {value} to {To}")
external("llvm") routine fptoui[From, To](value: From) -> To
@llvm_ir("{result} = fpext {From} {value} to {To}")
external("llvm") routine fpext[From, To](value: From) -> To
@llvm_ir("{result} = fptrunc {From} {value} to {To}")
external("llvm") routine fptrunc[From, To](value: From) -> To

# ============================================================================
# Integer Arithmetic Instructions
# ============================================================================

@llvm_ir("{result} = add {T} {a}, {b}")
external("llvm") routine add[T](a: T, b: T) -> T
@llvm_ir("{result} = sub {T} {a}, {b}")
external("llvm") routine sub[T](a: T, b: T) -> T
@llvm_ir("{result} = mul {T} {a}, {b}")
external("llvm") routine mul[T](a: T, b: T) -> T
@llvm_ir("{result} = sdiv {T} {a}, {b}")
external("llvm") routine sdiv[T](a: T, b: T) -> T
@llvm_ir("{result} = udiv {T} {a}, {b}")
external("llvm") routine udiv[T](a: T, b: T) -> T
@llvm_ir("{result} = srem {T} {a}, {b}")
external("llvm") routine srem[T](a: T, b: T) -> T
@llvm_ir("{result} = urem {T} {a}, {b}")
external("llvm") routine urem[T](a: T, b: T) -> T

# ============================================================================
# Float Arithmetic Instructions
# ============================================================================

@llvm_ir("{result} = fadd {T} {a}, {b}")
external("llvm") routine fadd[T](a: T, b: T) -> T
@llvm_ir("{result} = fsub {T} {a}, {b}")
external("llvm") routine fsub[T](a: T, b: T) -> T
@llvm_ir("{result} = fmul {T} {a}, {b}")
external("llvm") routine fmul[T](a: T, b: T) -> T
@llvm_ir("{result} = fdiv {T} {a}, {b}")
external("llvm") routine fdiv[T](a: T, b: T) -> T
@llvm_ir("{result} = frem {T} {a}, {b}")
external("llvm") routine frem[T](a: T, b: T) -> T
@llvm_ir("{result} = fneg {T} {value}")
external("llvm") routine fneg[T](value: T) -> T

# ============================================================================
# Bitwise Instructions (and/or are RF keywords, prefixed with bit_)
# ============================================================================

@llvm_ir("{result} = and {T} {a}, {b}")
external("llvm") routine bit_and[T](a: T, b: T) -> T
@llvm_ir("{result} = or {T} {a}, {b}")
external("llvm") routine bit_or[T](a: T, b: T) -> T
@llvm_ir("{result} = xor {T} {a}, {b}")
external("llvm") routine xor[T](a: T, b: T) -> T

# ============================================================================
# Shift Instructions
# ============================================================================

@llvm_ir("{result} = shl {T} {value}, {bits}")
external("llvm") routine shl[T](value: T, bits: T) -> T
@llvm_ir("{result} = ashr {T} {value}, {bits}")
external("llvm") routine ashr[T](value: T, bits: T) -> T
@llvm_ir("{result} = lshr {T} {value}, {bits}")
external("llvm") routine lshr[T](value: T, bits: T) -> T

