# ============================================================================
# Saturating Arithmetic (@llvm.s/u{add,sub}.sat)
# ============================================================================

### Returns the result of `signed_add_sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.sadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine signed_add_sat[T](a: T, b: T) -> T
### Returns the result of `unsigned_add_sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.uadd.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine unsigned_add_sat[T](a: T, b: T) -> T
### Returns the result of `signed_sub_sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.ssub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine signed_sub_sat[T](a: T, b: T) -> T
### Returns the result of `unsigned_sub_sat`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.usub.sat.{T}({T} {a}, {T} {b})")
external("llvm") routine unsigned_sub_sat[T](a: T, b: T) -> T

# ============================================================================
# Overflow Detection (@llvm.s/u{add,sub,mul}.with.overflow)
# ============================================================================

### Returns the result of `signed_add_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.sadd.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine signed_add_checked[T](a: T, b: T) -> (T, Bool)
### Returns the result of `unsigned_add_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.uadd.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine unsigned_add_checked[T](a: T, b: T) -> (T, Bool)
### Returns the result of `signed_sub_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.ssub.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine signed_sub_checked[T](a: T, b: T) -> (T, Bool)
### Returns the result of `unsigned_sub_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.usub.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine unsigned_sub_checked[T](a: T, b: T) -> (T, Bool)
### Returns the result of `signed_mul_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.smul.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine signed_mul_checked[T](a: T, b: T) -> (T, Bool)
### Returns the result of `unsigned_mul_checked`.
### :param a: The left-hand value.
### :param b: The right-hand value.
### :returns: The resulting `(T, Bool)` value.
@llvm_ir("{result} = call { {T}, i1 } @llvm.umul.with.overflow.{T}({T} {a}, {T} {b})")
external("llvm") routine unsigned_mul_checked[T](a: T, b: T) -> (T, Bool)

# ============================================================================
# Integer Bit Manipulation (@llvm.ctpop, @llvm.ctlz, etc.)
# ============================================================================

### Returns the result of `count_ones`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.ctpop.{T}({T} {value})")
external("llvm") routine count_ones[T](value: T) -> T
### Returns the result of `leading_zeros`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.ctlz.{T}({T} {value}, i1 false)")
external("llvm") routine leading_zeros[T](value: T) -> T
### Returns the result of `trailing_zeros`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.cttz.{T}({T} {value}, i1 false)")
external("llvm") routine trailing_zeros[T](value: T) -> T
### Returns the result of `reverse_bits`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.bitreverse.{T}({T} {value})")
external("llvm") routine reverse_bits[T](value: T) -> T
### Returns the result of `byte_swap`.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.bswap.{T}({T} {value})")
external("llvm") routine byte_swap[T](value: T) -> T
### Returns the absolute value.
### :param value: The value to use.
### :returns: The resulting `T` value.
@llvm_ir("{result} = call {T} @llvm.abs.{T}({T} {value}, i1 false)")
external("llvm") routine int_abs[T](value: T) -> T

