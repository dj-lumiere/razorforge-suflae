# FlagsType - Marker protocol for all flags types
# Every flags implicitly conforms to this protocol
# Provides: Diagnosable (-> Representable), Hashable, plus flags-specific routines
module Core

protocol FlagsType obeys Diagnosable, Hashable
  @[readonly, innate]
  routine U64.$create(from: Me) -> U64

  @[readonly, innate]
  routine Me.all_cases() -> List[Me]

  @[readonly, innate]
  routine Me.all_on() -> Me

  @[readonly, innate]
  routine Me.all_off() -> Me
