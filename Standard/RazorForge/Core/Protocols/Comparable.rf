# Comparable - Protocol for types that support ordering (<, <=, >, >=, <=>)
module Core

protocol Comparable obeys Equatable
  @readonly
  routine Me.$cmp(you: Me) -> ComparisonSign

  @[readonly, generated]
  routine Me.$lt(you: Me) -> Bool

  @[readonly, generated]
  routine Me.$le(you: Me) -> Bool

  @[readonly, generated]
  routine Me.$gt(you: Me) -> Bool

  @[readonly, generated]
  routine Me.$ge(you: Me) -> Bool
