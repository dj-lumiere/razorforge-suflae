# Shiftable - Protocol for types that support shift operations (<<, >>, <<<, >>>)
module Core

protocol Shiftable
  @readonly
  routine Me.$ashl(amount: Integral) -> Me

  @readonly
  routine Me.$ashr(amount: Integral) -> Me

  @readonly
  routine Me.$lshl(amount: Integral) -> Me

  @readonly
  routine Me.$lshr(amount: Integral) -> Me
