module Core

record Bool {
    private value: @intrinsic_type.i1
}

routine Bool.__eq__(you: Bool) -> Bool {
    danger! {
        return @intrinsic_routine.icmp.eq<i1>(me.value, you.value)
    }
}

routine Bool.to_text() -> Text {
    if me.value == 1 {
        return "true"
    }
    return "false"
}
