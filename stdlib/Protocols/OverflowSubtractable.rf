# OverflowSubtractable - Protocol for types that support overflow-handling subtraction (-%, -^, -?)
namespace Core

protocol OverflowSubtractable {
    @readonly
    routine Me.__sub_wrap__(you: Me) -> Me

    @readonly
    routine Me.__sub_sat__(you: Me) -> Me

    @readonly
    routine Me.__sub_checked__(you: Me) -> Maybe<Me>
}